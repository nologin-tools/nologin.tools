---
const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-white border-b border-neutral-200">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 h-12 flex items-center justify-between">
    <div class="flex items-center gap-6">
      <a href="/" class="font-bold text-base sm:text-lg tracking-tight text-neutral-900">
        nologin<span class="text-green-600">.</span>tools
      </a>
      <nav class="hidden md:flex items-center gap-6" aria-label="Main navigation">
        {[
          { label: 'Tools', path: '/' },
          { label: 'Badge', path: '/badge' },
          { label: 'About', path: '/about' },
          { label: 'Submit', path: '/submit' },
        ].map((item) => {
          const isActive = item.path === '/' ? currentPath === '/' : currentPath.startsWith(item.path);
          return (
            <a
              href={item.path}
              class:list={[
                'text-sm font-medium transition-colors',
                isActive
                  ? 'text-neutral-900'
                  : 'text-neutral-400 hover:text-neutral-900',
              ]}
            >
              {item.label}
            </a>
          );
        })}
      </nav>
    </div>
    <button
      id="mobile-menu-btn"
      class="md:hidden p-2 text-neutral-500 hover:text-neutral-950 transition-colors"
      aria-label="Toggle menu"
    >
      <svg
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
      >
        <path d="M3 12h18M3 6h18M3 18h18"></path>
      </svg>
    </button>
  </div>
  <nav
    id="mobile-menu"
    class="hidden md:hidden border-t border-neutral-200 bg-white px-6 py-6 space-y-4"
    aria-label="Mobile navigation"
  >
    <a
      href="/"
      class:list={[
        'block text-base font-medium',
        currentPath === '/' ? 'text-green-600' : 'text-neutral-500',
      ]}
    >
      Tools
    </a>
    <a
      href="/badge"
      class:list={[
        'block text-base font-medium',
        currentPath.startsWith('/badge')
          ? 'text-green-600'
          : 'text-neutral-500',
      ]}
    >
      Badge
    </a>
    <a
      href="/about"
      class:list={[
        'block text-base font-medium',
        currentPath === '/about'
          ? 'text-green-600'
          : 'text-neutral-500',
      ]}
    >
      About
    </a>
    <a
      href="/submit"
      class:list={[
        'block text-base font-medium',
        currentPath === '/submit'
          ? 'text-green-600'
          : 'text-neutral-500',
      ]}
    >
      Submit
    </a>
  </nav>
</header>


<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
