---
const currentPath = Astro.url.pathname;
---

<header class="bg-[#fdfdfc] border-b-2 border-neutral-900">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between">
    <div class="flex items-center gap-8">
      <a href="/" class="font-black text-xl tracking-tighter text-neutral-900 uppercase italic">
        nologin.tools
      </a>
      <nav class="hidden md:flex items-center gap-6 text-retro-mono" aria-label="Main navigation">
        {[
          { label: 'Tools', path: '/' },
          { label: 'Blog', path: '/blog' },
          { label: 'Badge', path: '/badge' },
          { label: 'About', path: '/about' },
          { label: 'Submit', path: '/submit' },
        ].map((item) => {
          const isActive = item.path === '/' ? currentPath === '/' : currentPath.startsWith(item.path);
          return (
            <a
              href={item.path}
              class:list={[
                'text-xs font-bold uppercase tracking-widest transition-all px-1',
                isActive
                  ? 'bg-neutral-900 text-white'
                  : 'text-neutral-500 hover:text-neutral-900 hover:underline decoration-2 underline-offset-4',
              ]}
            >
              {item.label}
            </a>
          );
        })}
      </nav>
      <button id="header-bookmark-btn" class="hidden lg:flex items-center gap-1.5 px-2 py-1 bg-yellow-300 border-2 border-neutral-900 shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] text-[10px] font-black uppercase tracking-tight hover:bg-yellow-400 transition-all active:translate-x-[1px] active:translate-y-[1px] active:shadow-none ml-6 cursor-pointer">
        ★ <span id="header-bookmark-key">Ctrl+D</span>
      </button>
    </div>
    <button
      id="mobile-menu-btn"
      class="md:hidden p-2 text-neutral-900 border-2 border-neutral-900 hover:bg-neutral-900 hover:text-white transition-all"
      aria-label="Toggle menu"
    >
      <svg
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="3"
        stroke-linecap="square"
      >
        <path d="M3 12h18M3 6h18M3 18h18"></path>
      </svg>
    </button>
  </div>
  <nav
    id="mobile-menu"
    class="hidden md:hidden border-t-2 border-neutral-900 bg-white px-6 py-8 space-y-6 text-retro-mono"
    aria-label="Mobile navigation"
  >
    <a
      href="/"
      class:list={[
        'block text-sm font-bold uppercase tracking-widest',
        currentPath === '/' ? 'text-neutral-900 underline decoration-2' : 'text-neutral-500',
      ]}
    >
      Tools
    </a>
    <a
      href="/blog"
      class:list={[
        'block text-sm font-bold uppercase tracking-widest',
        currentPath.startsWith('/blog')
          ? 'text-neutral-900 underline decoration-2'
          : 'text-neutral-500',
      ]}
    >
      Blog
    </a>
    <a
      href="/badge"
      class:list={[
        'block text-sm font-bold uppercase tracking-widest',
        currentPath.startsWith('/badge')
          ? 'text-neutral-900 underline decoration-2'
          : 'text-neutral-500',
      ]}
    >
      Badge
    </a>
    <a
      href="/about"
      class:list={[
        'block text-sm font-bold uppercase tracking-widest',
        currentPath === '/about'
          ? 'text-neutral-900 underline decoration-2'
          : 'text-neutral-500',
      ]}
    >
      About
    </a>
    <a
      href="/submit"
      class:list={[
        'block text-sm font-bold uppercase tracking-widest',
        currentPath === '/submit'
          ? 'text-neutral-900 underline decoration-2'
          : 'text-neutral-500',
      ]}
    >
      Submit
    </a>
  </nav>
</header>


<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });

  const headerBookmarkKey = document.getElementById('header-bookmark-key');
  const headerBookmarkBtn = document.getElementById('header-bookmark-btn');
  
  const isMac = navigator.platform.toUpperCase().indexOf('MAC') >= 0;
  if (headerBookmarkKey) {
    headerBookmarkKey.textContent = isMac ? '⌘+D' : 'Ctrl+D';
  }

  headerBookmarkBtn?.addEventListener('click', () => {
    const shortcut = isMac ? 'Command/Cmd + D' : 'Control/Ctrl + D';
    alert(`Press ${shortcut} to bookmark this site.`);
  });
</script>
