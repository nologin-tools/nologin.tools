---
import Layout from '../layouts/Layout.astro';
import HealthBadge from './HealthBadge.astro';
import TagPicker from './TagPicker.astro';
import { formatDate, timeAgo } from '../lib/utils';
import { sortTagsCategoryFirst } from '../lib/tags';
import { resolveEffectiveStatus, type EffectiveStatus } from '../lib/health';
import { DEFAULT_LOCALE, type Locale } from '../i18n/config';
import { t, loadTranslations, getLocalizedPath } from '../i18n/utils';

interface Props {
  tool: {
    id: number;
    slug: string;
    name: string;
    url: string;
    description: string | null;
    coreTask: string;
    status: string;
    approvedAt: Date | string | null;
    archiveUrl: string | null;
    isFeatured: boolean;
    submitterEmail: string | null;
    twitterUrl?: string | null;
    githubUrl?: string | null;
    discordUrl?: string | null;
    repoUrl?: string | null;
    githubStars?: number | null;
    githubForks?: number | null;
    githubLicense?: string | null;
    githubLanguage?: string | null;
    githubUpdatedAt?: Date | string | null;
    githubFetchedAt?: Date | string | null;
  };
  toolTags: { tagKey: string; tagValue: string }[];
  recentChecks: { isOnline: boolean; httpStatus?: number | null; responseTimeMs?: number | null; checkedAt: Date }[];
  healthHistory: { isOnline: boolean; checkedAt: Date }[];
  slug: string;
  locale?: Locale;
}

const { tool, toolTags, recentChecks, healthHistory, slug, locale = DEFAULT_LOCALE } = Astro.props;
await loadTranslations(locale);

const effectiveStatus = resolveEffectiveStatus(recentChecks);
const latestHealth = recentChecks[0] ?? null;

// Group health by day
const healthByDay = new Map<string, EffectiveStatus>();
const checksPerDay = new Map<string, boolean[]>();
for (const check of healthHistory) {
  const day = check.checkedAt.toISOString().split('T')[0];
  if (!checksPerDay.has(day)) checksPerDay.set(day, []);
  checksPerDay.get(day)!.push(check.isOnline);
}
for (const [day, results] of checksPerDay) {
  const onlineCount = results.filter(Boolean).length;
  if (onlineCount === results.length) healthByDay.set(day, 'online');
  else if (onlineCount === 0) healthByDay.set(day, 'offline');
  else healthByDay.set(day, 'unstable');
}

// Generate last 14 days for timeline
const days: { date: string; label: string; status: EffectiveStatus | null }[] = [];
for (let i = 13; i >= 0; i--) {
  const d = new Date(Date.now() - i * 86400000);
  const key = d.toISOString().split('T')[0];
  days.push({
    date: key,
    label: d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' }),
    status: healthByDay.get(key) ?? null,
  });
}

const hasSocialLinks = tool.twitterUrl || tool.githubUrl || tool.discordUrl;
const hasRepoData = tool.repoUrl;
const repoPath = tool.repoUrl ? tool.repoUrl.replace('https://github.com/', '').replace(/\/$/, '') : '';

function formatNumber(n: number): string {
  if (n >= 1000) return (n / 1000).toFixed(1).replace(/\.0$/, '') + 'k';
  return String(n);
}

const isVerified = tool.status === 'approved';
const isPending = tool.status === 'pending';
const isRejected = tool.status === 'rejected';
const isOffline = effectiveStatus === 'offline';

const approvedDate = tool.approvedAt ? new Date(tool.approvedAt).toISOString().split('T')[0] : undefined;

const sameAs = [tool.twitterUrl, tool.githubUrl, tool.discordUrl, tool.repoUrl].filter(Boolean) as string[];
const keywords = toolTags.map(t => t.tagValue).join(', ');

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: tool.name,
  url: tool.url,
  description: tool.description || '',
  applicationCategory: 'WebApplication',
  operatingSystem: 'All',
  image: `https://nologin.tools/api/og/${slug}`,
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
    url: tool.url,
    availability: 'https://schema.org/InStock',
  },
  ...(approvedDate ? { datePublished: approvedDate } : {}),
  ...(sameAs.length > 0 ? { sameAs } : {}),
  ...(keywords ? { keywords } : {}),
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://nologin.tools' },
    { '@type': 'ListItem', position: 2, name: tool.name, item: `https://nologin.tools/tool/${slug}` },
  ],
};
---

<Layout
  title={tool.name}
  description={tool.description || t(locale, 'tool.defaultDescription', { name: tool.name })}
  ogType="article"
  canonicalOverride={`/tool/${slug}`}
  publishedTime={approvedDate}
  ogImagePath={`/api/og/${slug}`}
  locale={locale}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />

  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-8 sm:py-12">
    <!-- Breadcrumb -->
    <nav aria-label="Breadcrumb" class="mb-8 sm:mb-10">
      <ol class="flex items-center gap-2 text-sm font-bold text-neutral-400">
        <li>
          <a href={getLocalizedPath('/', locale)} class="hover:text-neutral-900 transition-colors">{t(locale, 'common.home')}</a>
        </li>
        <li aria-hidden="true">
          <svg class="w-4 h-4 text-neutral-300" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd" /></svg>
        </li>
        <li aria-current="page" class="text-neutral-900 truncate max-w-[200px] sm:max-w-none">{tool.name}</li>
      </ol>
    </nav>

    <!-- Status banners -->
    {isPending && (
      <div class="border-l-4 border-amber-500 pl-4 py-2 bg-amber-50 mb-8">
        <p class="text-amber-900 font-bold text-sm">{t(locale, 'tool.pendingReview')}</p>
        <p class="text-xs text-amber-800/70 leading-relaxed">
          {t(locale, 'tool.pendingDesc')}
        </p>
      </div>
    )}

    <!-- Main content -->
    <div class="space-y-8">
      <!-- Header -->
      <div>
        <div class="flex items-center gap-3 mb-3">
          <img
            src={`https://www.google.com/s2/favicons?domain=${new URL(tool.url).hostname}&sz=32`}
            alt=""
            width="24"
            height="24"
            class="w-6 h-6 object-contain"
            onerror={`this.style.display='none'`}
          />
          <h1 class="text-2xl font-bold text-neutral-900">{tool.name}</h1>
          {tool.isFeatured && (
            <span class="text-yellow-500 text-sm" title={t(locale, 'common.featured')}>★</span>
          )}
        </div>

        <div class="flex flex-wrap items-center gap-3 text-sm text-neutral-400 mb-4">
          <span>{new URL(tool.url).hostname}</span>
          {isVerified && tool.approvedAt && (
            <>
              <span class="text-neutral-300">·</span>
              <span>{t(locale, 'tool.verified', { date: formatDate(tool.approvedAt) })}</span>
            </>
          )}
          <span class="text-neutral-300">·</span>
          <HealthBadge status={effectiveStatus} lastCheckedAt={latestHealth?.checkedAt ?? null} locale={locale} />
        </div>

        {hasSocialLinks && (
          <div class="flex items-center gap-3 text-sm text-neutral-500 mb-4">
            {tool.twitterUrl && (
              <a href={tool.twitterUrl} target="_blank" rel="noopener noreferrer" class="hover:text-neutral-900 transition-colors">Twitter</a>
            )}
            {tool.twitterUrl && (tool.githubUrl || tool.discordUrl) && (
              <span class="text-neutral-300">·</span>
            )}
            {tool.githubUrl && (
              <a href={tool.githubUrl} target="_blank" rel="noopener noreferrer" class="hover:text-neutral-900 transition-colors">GitHub</a>
            )}
            {tool.githubUrl && tool.discordUrl && (
              <span class="text-neutral-300">·</span>
            )}
            {tool.discordUrl && (
              <a href={tool.discordUrl} target="_blank" rel="noopener noreferrer" class="hover:text-neutral-900 transition-colors">Discord</a>
            )}
          </div>
        )}

        <div class="flex items-center gap-4">
          {isOffline ? (
            <>
              <button class="btn-minimal-primary opacity-50 cursor-not-allowed" disabled>{t(locale, 'tool.toolOffline')}</button>
              {tool.archiveUrl && (
                <a href={tool.archiveUrl} target="_blank" rel="noopener noreferrer" class="text-sm text-neutral-500 hover:text-neutral-900 transition-colors">
                  {t(locale, 'tool.viewArchive')}
                </a>
              )}
            </>
          ) : (
            <a href={tool.url} target="_blank" rel="noopener noreferrer" class="btn-minimal-primary">
              {t(locale, 'tool.openTool')}
              <svg class="ml-1.5 w-3.5 h-3.5" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M5.22 14.78a.75.75 0 010-1.06l7.22-7.22H5.75a.75.75 0 010-1.5h8.5a.75.75 0 01.75.75v8.5a.75.75 0 01-1.5 0V6.56l-7.22 7.22a.75.75 0 01-1.06 0z" clip-rule="evenodd" />
              </svg>
            </a>
          )}
          {isVerified && (
            <button id="suggest-edit-btn" class="text-sm text-neutral-500 hover:text-neutral-900 transition-colors">
              {t(locale, 'tool.suggestEdit')}
            </button>
          )}
        </div>
      </div>

      <!-- Description -->
      <div class="border-t border-neutral-100 pt-8">
        <h2 class="text-sm font-medium text-neutral-500 mb-3">{t(locale, 'tool.descriptionLabel')}</h2>
        <p class="text-neutral-700 text-base leading-relaxed">{tool.description}</p>
      </div>

      <!-- No-Login Task -->
      <div class="border-l-2 border-green-500 pl-4">
        <h2 class="text-sm font-medium text-neutral-500 mb-1">{t(locale, 'tool.noLoginTask')}</h2>
        <p class="text-neutral-900 font-medium text-base italic">
          "{tool.coreTask}"
        </p>
      </div>

      <!-- Tags -->
      {toolTags.length > 0 && (
        <div>
          <h2 class="text-sm font-medium text-neutral-500 mb-3">{t(locale, 'tool.tagsLabel')}</h2>
          <div class="flex flex-wrap items-center gap-x-1 text-sm text-neutral-600">
            {sortTagsCategoryFirst(toolTags).map((tag, i) => (
              <>
                {i > 0 && <span class="text-neutral-300">,</span>}
                {tag.tagKey === 'category' ? (
                  <a
                    href={`/?${tag.tagKey}=${encodeURIComponent(tag.tagValue)}`}
                    class="text-blue-600 hover:underline"
                  >
                    {tag.tagValue}
                  </a>
                ) : (
                  <span>{tag.tagValue}</span>
                )}
              </>
            ))}
          </div>
        </div>
      )}

      <!-- Health History -->
      <div class="border-t border-neutral-100 pt-8">
        <h2 class="text-sm font-medium text-neutral-500 mb-3">{t(locale, 'tool.healthHistory')}</h2>
        <div class="flex flex-wrap items-center gap-1 mb-3">
          {days.map((day) => (
            <div
              class:list={[
                'w-5 h-5 rounded transition-all duration-300',
                day.status === null
                  ? 'bg-neutral-100'
                  : day.status === 'online'
                    ? 'bg-green-400'
                    : day.status === 'unstable'
                      ? 'bg-amber-400'
                      : 'bg-red-400',
              ]}
              title={`${day.label}: ${day.status === null ? t(locale, 'health.noData') : day.status === 'online' ? t(locale, 'health.online') : day.status === 'unstable' ? t(locale, 'health.unstable') : t(locale, 'health.offline')}`}
            >
            </div>
          ))}
        </div>
        <div class="flex items-center gap-4 text-xs text-neutral-400">
          <span>{t(locale, 'tool.daysAgoToday')}</span>
          <span class="text-neutral-300">·</span>
          <span>{t(locale, 'tool.uptime', { percent: Math.round((days.filter(d => d.status === 'online').length / days.filter(d => d.status !== null).length || 0) * 100) })}</span>
        </div>
      </div>

      <!-- GitHub Repository -->
      {hasRepoData && (
        <div class="border-t border-neutral-100 pt-8">
          <h2 class="text-sm font-medium text-neutral-500 mb-3">{t(locale, 'tool.repository')}</h2>
          <p class="text-sm mb-2">
            <a href={tool.repoUrl!} target="_blank" rel="noopener noreferrer" class="text-blue-600 hover:underline">{repoPath}</a>
          </p>
          <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-sm text-neutral-600">
            {tool.githubStars != null && (
              <span>&#9733; {formatNumber(tool.githubStars)}</span>
            )}
            {tool.githubForks != null && (
              <>
                {tool.githubStars != null && <span class="text-neutral-300">·</span>}
                <span>&#9413; {formatNumber(tool.githubForks)}</span>
              </>
            )}
            {tool.githubLanguage && (
              <>
                <span class="text-neutral-300">·</span>
                <span>{tool.githubLanguage}</span>
              </>
            )}
            {tool.githubLicense && (
              <>
                <span class="text-neutral-300">·</span>
                <span>{tool.githubLicense}</span>
              </>
            )}
            {tool.githubUpdatedAt && (
              <>
                <span class="text-neutral-300">·</span>
                <span>{t(locale, 'tool.updated', { time: timeAgo(tool.githubUpdatedAt) })}</span>
              </>
            )}
          </div>
        </div>
      )}

      <!-- Badge Preview -->
      {(isVerified || isPending) && (
        <div class="border-t border-neutral-100 pt-8">
          <a href={getLocalizedPath(`/badge/${slug}${isVerified ? '#embed' : ''}`, locale)} class="text-sm text-blue-600 hover:underline">
            {isVerified ? t(locale, 'tool.viewBadgeEmbed') : t(locale, 'tool.viewBadgePage')} &rarr;
          </a>
        </div>
      )}

      {/* Resubmit form if rejected */}
      {isRejected && (
        <div class="border-t pt-8 mt-8">
          <h3 class="text-xl font-bold text-neutral-900 mb-6">{t(locale, 'tool.resubmitTitle')}</h3>
          <form id="resubmit-form" class="space-y-6" novalidate>
            <input type="hidden" name="toolId" value={tool.id} />

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label for="rs-name" class="block text-sm font-medium text-neutral-500 mb-2">
                  Tool Name <span class="text-red-500">*</span>
                </label>
                <input
                  type="text"
                  id="rs-name"
                  name="name"
                  required
                  value={tool.name}
                  class="w-full px-4 py-3 bg-neutral-50 border border-neutral-200 rounded text-sm focus:outline-none focus:ring-2 focus:ring-green-500"
                />
                <p class="text-xs text-red-500 mt-1 hidden" data-rs-error="name"></p>
              </div>

              <div>
                <label for="rs-url" class="block text-sm font-medium text-neutral-500 mb-2">
                  Tool URL <span class="text-red-500">*</span>
                </label>
                <input
                  type="url"
                  id="rs-url"
                  name="url"
                  required
                  value={tool.url}
                  class="w-full px-4 py-3 bg-neutral-50 border border-neutral-200 rounded text-sm focus:outline-none focus:ring-2 focus:ring-green-500"
                />
                <p class="text-xs text-red-500 mt-1 hidden" data-rs-error="url"></p>
              </div>
            </div>

            <div>
              <label for="rs-description" class="block text-sm font-medium text-neutral-500 mb-2">
                Description <span class="text-red-500">*</span>
              </label>
              <textarea
                id="rs-description"
                name="description"
                required
                rows="4"
                class="w-full px-4 py-3 bg-neutral-50 border border-neutral-200 rounded text-sm focus:outline-none focus:ring-2 focus:ring-green-500 resize-none"
              >{tool.description}</textarea>
              <p class="text-xs text-red-500 mt-1 hidden" data-rs-error="description"></p>
            </div>

            <div>
              <label for="rs-coreTask" class="block text-sm font-medium text-neutral-500 mb-2">
                What can you do without login? <span class="text-red-500">*</span>
              </label>
              <input
                type="text"
                id="rs-coreTask"
                name="coreTask"
                required
                value={tool.coreTask}
                class="w-full px-4 py-3 bg-neutral-50 border border-neutral-200 rounded text-sm focus:outline-none focus:ring-2 focus:ring-green-500"
              />
              <p class="text-xs text-red-500 mt-1 hidden" data-rs-error="coreTask"></p>
            </div>

            <div>
              <label class="flex items-start gap-4 p-4 border border-neutral-200 rounded cursor-pointer hover:bg-neutral-50 transition-colors">
                <input
                  type="checkbox"
                  id="rs-pledge"
                  name="pledge"
                  required
                  checked
                  class="mt-1 w-5 h-5 text-green-600 border-neutral-300 rounded focus:ring-green-500"
                />
                <span class="text-sm text-neutral-700 font-medium">
                  I confirm this tool's core functionality works without creating an
                  account or logging in. <span class="text-red-500 font-bold">*</span>
                </span>
              </label>
              <p class="text-xs text-red-500 mt-1 hidden" data-rs-error="pledge"></p>
            </div>

            <div>
              <label for="rs-submitterEmail" class="block text-sm font-medium text-neutral-500 mb-2">
                Email <span class="text-neutral-300">(optional)</span>
              </label>
              <input
                type="email"
                id="rs-submitterEmail"
                name="submitterEmail"
                value={tool.submitterEmail || ''}
                class="w-full px-4 py-3 bg-neutral-50 border border-neutral-200 rounded text-sm focus:outline-none focus:ring-2 focus:ring-green-500"
              />
              <p class="text-xs text-neutral-400 mt-2">
                Only visible to reviewers.
              </p>
              <p class="text-xs text-red-500 mt-1 hidden" data-rs-error="submitterEmail"></p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div class="md:col-span-2">
                <label for="rs-repoUrl" class="block text-sm font-medium text-neutral-500 mb-2">
                  Repository URL <span class="text-neutral-300">(optional)</span>
                </label>
                <input
                  type="url"
                  id="rs-repoUrl"
                  name="repoUrl"
                  value={tool.repoUrl || ''}
                  placeholder="https://github.com/owner/repo"
                  class="w-full px-4 py-3 bg-neutral-50 border border-neutral-200 rounded text-sm focus:outline-none focus:ring-2 focus:ring-green-500"
                />
                <p class="text-xs text-neutral-400 mt-2">
                  Filling this will automatically mark the tool as open source.
                </p>
                <p class="text-xs text-red-500 mt-1 hidden" data-rs-error="repoUrl"></p>
              </div>
              <div>
                <label for="rs-twitterUrl" class="block text-sm font-medium text-neutral-500 mb-2">
                  Twitter / X <span class="text-neutral-300">(optional)</span>
                </label>
                <input
                  type="url"
                  id="rs-twitterUrl"
                  name="twitterUrl"
                  value={tool.twitterUrl || ''}
                  placeholder="https://x.com/username"
                  class="w-full px-4 py-3 bg-neutral-50 border border-neutral-200 rounded text-sm focus:outline-none focus:ring-2 focus:ring-green-500"
                />
                <p class="text-xs text-red-500 mt-1 hidden" data-rs-error="twitterUrl"></p>
              </div>
              <div>
                <label for="rs-githubUrl" class="block text-sm font-medium text-neutral-500 mb-2">
                  GitHub Profile <span class="text-neutral-300">(optional)</span>
                </label>
                <input
                  type="url"
                  id="rs-githubUrl"
                  name="githubUrl"
                  value={tool.githubUrl || ''}
                  placeholder="https://github.com/username"
                  class="w-full px-4 py-3 bg-neutral-50 border border-neutral-200 rounded text-sm focus:outline-none focus:ring-2 focus:ring-green-500"
                />
                <p class="text-xs text-red-500 mt-1 hidden" data-rs-error="githubUrl"></p>
              </div>
              <div>
                <label for="rs-discordUrl" class="block text-sm font-medium text-neutral-500 mb-2">
                  Discord <span class="text-neutral-300">(optional)</span>
                </label>
                <input
                  type="url"
                  id="rs-discordUrl"
                  name="discordUrl"
                  value={tool.discordUrl || ''}
                  placeholder="https://discord.gg/invite-code"
                  class="w-full px-4 py-3 bg-neutral-50 border border-neutral-200 rounded text-sm focus:outline-none focus:ring-2 focus:ring-green-500"
                />
                <p class="text-xs text-red-500 mt-1 hidden" data-rs-error="discordUrl"></p>
              </div>
            </div>

            <div class="pt-4">
              <h4 class="text-sm font-medium text-neutral-500 mb-4">Update Tags</h4>
              <TagPicker selectedTags={toolTags.map(t => ({ key: t.tagKey, value: t.tagValue }))} />
            </div>

            <div id="resubmit-error" class="hidden p-4 bg-red-50 border border-red-200 rounded text-sm text-red-700 font-bold"></div>

            <button
              type="submit"
              id="resubmit-btn"
              class="btn-minimal-primary w-full justify-center py-3"
            >
              Resubmit Tool
            </button>
          </form>
        </div>
      )}
    </div>
  </div>

  {/* Edit Suggestion Modal */}
  <div id="edit-form" class="hidden fixed inset-0 z-[60] flex items-center justify-center px-6">
    <div class="absolute inset-0 bg-neutral-900/40 backdrop-blur-sm"></div>
    <div class="relative bg-white border rounded-lg w-full max-w-xl max-h-[90vh] overflow-y-auto p-8">
      <h3 class="text-xl font-bold text-neutral-900 mb-6">{t(locale, 'tool.suggestEditTitle')}</h3>
      <form id="edit-suggestion-form" class="space-y-6">
        <input type="hidden" name="toolId" value={tool.id} />
        <div>
          <label for="edit-field" class="block text-sm font-medium text-neutral-500 mb-2">
            Field to edit
          </label>
          <select
            id="edit-field"
            name="fieldName"
            class="w-full px-4 py-3 bg-neutral-50 border border-neutral-200 rounded text-sm focus:outline-none focus:ring-2 focus:ring-green-500 appearance-none"
          >
            <option value="name">Name</option>
            <option value="description">Description</option>
            <option value="coreTask">Core Task</option>
            <option value="url">URL</option>
            <option value="tags">Tags</option>
          </select>
        </div>
        <div id="edit-value-wrap">
          <label for="edit-value" class="block text-sm font-medium text-neutral-500 mb-2">
            New value
          </label>
          <input
            type="text"
            id="edit-value"
            name="newValue"
            class="w-full px-4 py-3 bg-neutral-50 border border-neutral-200 rounded text-sm focus:outline-none focus:ring-2 focus:ring-green-500"
          />
        </div>
        <div id="edit-tags-wrap" class="hidden">
          <label class="block text-sm font-medium text-neutral-500 mb-2">
            New tags
          </label>
          <TagPicker selectedTags={toolTags.map(t => ({ key: t.tagKey, value: t.tagValue }))} />
        </div>
        <div>
          <label for="edit-reason" class="block text-sm font-medium text-neutral-500 mb-2">
            Reason <span class="text-neutral-300">(optional)</span>
          </label>
          <textarea
            id="edit-reason"
            name="reason"
            rows="3"
            placeholder="Why should this be changed?"
            class="w-full px-4 py-3 bg-neutral-50 border border-neutral-200 rounded text-sm focus:outline-none focus:ring-2 focus:ring-green-500 resize-none"
          ></textarea>
        </div>
        <div id="edit-msg" class="hidden p-4 rounded text-sm font-bold"></div>
        <div id="edit-buttons" class="flex flex-col sm:flex-row gap-3 pt-2">
          <button type="submit" class="btn-minimal-primary flex-1 justify-center py-3">Submit Suggestion</button>
          <button type="button" id="cancel-edit" class="flex-1 text-center py-3 text-sm text-neutral-500 hover:text-neutral-900 transition-colors border border-neutral-200 rounded">Cancel</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    const editBtn = document.getElementById('suggest-edit-btn');
    const editForm = document.getElementById('edit-form');
    const cancelBtn = document.getElementById('cancel-edit');
    const editSuggestionForm = document.getElementById('edit-suggestion-form') as HTMLFormElement | null;
    const editMsg = document.getElementById('edit-msg');

    const editFieldSelect = document.getElementById('edit-field') as HTMLSelectElement | null;
    const editValueWrap = document.getElementById('edit-value-wrap');
    const editTagsWrap = document.getElementById('edit-tags-wrap');

    editFieldSelect?.addEventListener('change', () => {
      const isTags = editFieldSelect.value === 'tags';
      editValueWrap?.classList.toggle('hidden', isTags);
      editTagsWrap?.classList.toggle('hidden', !isTags);
    });

    editBtn?.addEventListener('click', () => {
      editForm?.classList.toggle('hidden');
    });

    cancelBtn?.addEventListener('click', () => {
      editForm?.classList.add('hidden');
    });

    editSuggestionForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(editSuggestionForm);
      const fieldName = formData.get('fieldName') as string;

      let newValue: string;
      if (fieldName === 'tags') {
        // Collect tags from TagPicker inside the edit form
        const tagEntries: { key: string; value: string }[] = [];
        for (const [key, value] of formData.entries()) {
          if (key.startsWith('tag_')) {
            const tagKey = key.replace('tag_', '').replace('[]', '');
            tagEntries.push({ key: tagKey, value: value as string });
          }
        }
        if (tagEntries.length === 0) {
          if (editMsg) {
            editMsg.textContent = 'Please select at least one tag.';
            editMsg.className = 'text-sm text-red-500';
            editMsg.classList.remove('hidden');
          }
          return;
        }
        newValue = JSON.stringify(tagEntries);
      } else {
        newValue = (formData.get('newValue') as string || '').trim();
        let validationError = '';
        if (!newValue) {
          validationError = 'New value cannot be empty.';
        } else if (fieldName === 'name' && (newValue.length < 2 || newValue.length > 100)) {
          validationError = 'Name must be between 2 and 100 characters.';
        } else if (fieldName === 'description' && newValue.length > 500) {
          validationError = 'Description must be max 500 characters.';
        } else if (fieldName === 'coreTask' && newValue.length > 200) {
          validationError = 'Core task must be max 200 characters.';
        } else if (fieldName === 'url') {
          try { new URL(newValue); } catch { validationError = 'Please enter a valid URL.'; }
        }
        if (validationError) {
          if (editMsg) {
            editMsg.textContent = validationError;
            editMsg.className = 'text-sm text-red-500';
            editMsg.classList.remove('hidden');
          }
          return;
        }
      }

      try {
        const res = await fetch('/api/edit', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            toolId: Number(formData.get('toolId')),
            fieldName,
            newValue,
            reason: formData.get('reason') || undefined,
          }),
        });

        const result = await res.json();
        if (editMsg) {
          if (result.ok) {
            editMsg.textContent = 'Edit suggestion submitted! It will be reviewed.';
            editMsg.className = 'text-sm text-green-600';
            editMsg.classList.remove('hidden');
            editSuggestionForm.reset();
            document.getElementById('edit-buttons')?.classList.add('hidden');
            setTimeout(() => {
              editForm?.classList.add('hidden');
              editMsg.classList.add('hidden');
              editMsg.textContent = '';
              document.getElementById('edit-buttons')?.classList.remove('hidden');
              // Reset field selector and TagPicker visibility
              if (editFieldSelect) editFieldSelect.value = 'name';
              editValueWrap?.classList.remove('hidden');
              editTagsWrap?.classList.add('hidden');
            }, 1500);
          } else {
            editMsg.textContent = result.error || 'Failed to submit edit.';
            editMsg.className = 'text-sm text-red-500';
            editMsg.classList.remove('hidden');
          }
        }
      } catch {
        if (editMsg) {
          editMsg.textContent = 'Network error. Please try again.';
          editMsg.className = 'text-sm text-red-500';
          editMsg.classList.remove('hidden');
        }
      }
    });

    // Resubmit form
    const resubmitForm = document.getElementById('resubmit-form') as HTMLFormElement | null;
    const resubmitBtn = document.getElementById('resubmit-btn') as HTMLButtonElement | null;
    const resubmitError = document.getElementById('resubmit-error');

    resubmitForm?.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Clear errors
      document.querySelectorAll('[data-rs-error]').forEach((el) => el.classList.add('hidden'));
      resubmitError?.classList.add('hidden');

      const formData = new FormData(resubmitForm);
      const data: Record<string, any> = {
        toolId: Number(formData.get('toolId')),
        name: formData.get('name'),
        url: formData.get('url'),
        description: formData.get('description'),
        pledge: formData.get('pledge') === 'on',
        coreTask: formData.get('coreTask'),
        submitterEmail: formData.get('submitterEmail') || '',
        repoUrl: formData.get('repoUrl') || '',
        twitterUrl: formData.get('twitterUrl') || '',
        githubUrl: formData.get('githubUrl') || '',
        discordUrl: formData.get('discordUrl') || '',
        tags: [] as { key: string; value: string }[],
      };

      // Collect tags
      for (const [key, value] of formData.entries()) {
        if (key.startsWith('tag_')) {
          const tagKey = key.replace('tag_', '').replace('[]', '');
          data.tags.push({ key: tagKey, value: value as string });
        }
      }

      if (resubmitBtn) {
        resubmitBtn.disabled = true;
        resubmitBtn.textContent = 'Resubmitting...';
      }

      try {
        const res = await fetch('/api/resubmit', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });

        const result = await res.json();

        if (result.ok) {
          window.location.href = `/tool/${result.data.slug}`;
        } else {
          if (result.details) {
            for (const [field, msg] of Object.entries(result.details)) {
              const el = document.querySelector(`[data-rs-error="${field}"]`);
              if (el) {
                el.textContent = msg as string;
                el.classList.remove('hidden');
              }
            }
          }
          if (resubmitError) {
            resubmitError.textContent = result.error || 'Resubmission failed.';
            resubmitError.classList.remove('hidden');
          }
        }
      } catch {
        if (resubmitError) {
          resubmitError.textContent = 'Network error. Please try again.';
          resubmitError.classList.remove('hidden');
        }
      } finally {
        if (resubmitBtn) {
          resubmitBtn.disabled = false;
          resubmitBtn.textContent = 'Resubmit Tool';
        }
      }
    });
  </script>
</Layout>
