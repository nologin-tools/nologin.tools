---
import Layout from '../layouts/Layout.astro';
import { t, loadTranslations, getLocalizedPath } from '../i18n/utils';
import type { Locale } from '../i18n/config';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
await loadTranslations(locale);
---

<Layout
  title={t(locale, 'badge.title')}
  description={t(locale, 'badge.description')}
  locale={locale}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    inLanguage: locale,
    mainEntity: [
      {
        '@type': 'Question',
        name: t(locale, 'badge.faq.q1'),
        acceptedAnswer: { '@type': 'Answer', text: t(locale, 'badge.faq.a1') },
      },
      {
        '@type': 'Question',
        name: t(locale, 'badge.faq.q2'),
        acceptedAnswer: { '@type': 'Answer', text: t(locale, 'badge.faq.a2') },
      },
      {
        '@type': 'Question',
        name: t(locale, 'badge.faq.q3'),
        acceptedAnswer: { '@type': 'Answer', text: t(locale, 'badge.faq.a3') },
      },
      {
        '@type': 'Question',
        name: t(locale, 'badge.faq.q4'),
        acceptedAnswer: { '@type': 'Answer', text: t(locale, 'badge.faq.a4') },
      },
    ],
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'HowTo',
    inLanguage: locale,
    name: t(locale, 'badge.howToName'),
    description: t(locale, 'badge.joinDesc'),
    step: [
      { '@type': 'HowToStep', position: 1, name: t(locale, 'badge.step1'), text: t(locale, 'badge.step1'), url: `https://nologin.tools${getLocalizedPath('/submit', locale)}` },
      { '@type': 'HowToStep', position: 2, name: t(locale, 'badge.step2'), text: t(locale, 'badge.step2') },
      { '@type': 'HowToStep', position: 3, name: t(locale, 'badge.step3'), text: t(locale, 'badge.step3') },
      { '@type': 'HowToStep', position: 4, name: t(locale, 'badge.step4'), text: t(locale, 'badge.step4') },
    ],
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: t(locale, 'common.home'), item: `https://nologin.tools${getLocalizedPath('/', locale)}` },
      { '@type': 'ListItem', position: 2, name: t(locale, 'badge.title'), item: `https://nologin.tools${getLocalizedPath('/badge', locale)}` },
    ],
  })} />

  <div class="max-w-4xl mx-auto px-6 py-16 sm:py-24">
    <!-- Breadcrumb -->
    <nav aria-label="Breadcrumb" class="mb-8">
      <ol class="flex items-center gap-2 text-sm font-bold text-neutral-400">
        <li>
          <a href={getLocalizedPath('/', locale)} class="hover:text-neutral-900 transition-colors">{t(locale, 'common.home')}</a>
        </li>
        <li aria-hidden="true">
          <svg class="w-4 h-4 text-neutral-300" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd" /></svg>
        </li>
        <li aria-current="page" class="text-neutral-900">{t(locale, 'badge.title')}</li>
      </ol>
    </nav>
    <!-- Hero -->
    <div class="text-center mb-16">
      <div class="mb-8">
        <img
          src="/badge.svg"
          alt="NoLogin Verified"
          class="w-48 mx-auto"
        />
      </div>
      <h1 class="text-2xl font-bold tracking-tight text-neutral-900 mb-4">
        {t(locale, 'badge.heroTitle')}
      </h1>
      <p class="text-base text-neutral-500 max-w-2xl mx-auto leading-relaxed">
        {t(locale, 'badge.heroDesc')}
      </p>
    </div>

    <!-- What is NoLogin Verified? -->
    <div class="border-b pb-8 mb-8">
      <h2 class="text-xl font-bold text-neutral-900 mb-4">{t(locale, 'badge.whatIsTitle')}</h2>
      <div class="space-y-3 text-neutral-600 leading-relaxed">
        <p>
          {t(locale, 'badge.whatIsP1')} <a href="https://nologintools.org" target="_blank" rel="noopener noreferrer" class="text-green-600 hover:text-green-700 font-semibold transition-colors">NoLoginTools.org</a> {t(locale, 'badge.whatIsP1Suffix')}
        </p>
        <p>
          {t(locale, 'badge.whatIsP2')}
        </p>
      </div>
    </div>

    <!-- Three-column grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-16">
      <div class="border rounded-lg p-4 text-center">
        <h3 class="font-bold text-neutral-900 mb-1 text-sm">{t(locale, 'badge.noAccountsTitle')}</h3>
        <p class="text-sm text-neutral-500">{t(locale, 'badge.noAccountsDesc')}</p>
      </div>
      <div class="border rounded-lg p-4 text-center">
        <h3 class="font-bold text-neutral-900 mb-1 text-sm">{t(locale, 'badge.privacyFirstTitle')}</h3>
        <p class="text-sm text-neutral-500">{t(locale, 'badge.privacyFirstDesc')}</p>
      </div>
      <div class="border rounded-lg p-4 text-center">
        <h3 class="font-bold text-neutral-900 mb-1 text-sm">{t(locale, 'badge.instantValueTitle')}</h3>
        <p class="text-sm text-neutral-500">{t(locale, 'badge.instantValueDesc')}</p>
      </div>
    </div>

    <div class="space-y-12">
      <!-- Two Column Layout for Users/Creators -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- For Users -->
        <section class="border rounded-lg p-6">
          <h2 class="text-lg font-bold text-neutral-900 mb-4 flex items-center gap-2">
            <span class="w-6 h-6 rounded bg-green-100 flex items-center justify-center text-green-600 text-xs font-bold">U</span>
            {t(locale, 'badge.sealTitle')}
          </h2>
          <p class="text-sm text-neutral-600 leading-relaxed mb-4">
            {t(locale, 'badge.sealDesc')}
          </p>
          <ul class="space-y-3">
            {[
              { title: t(locale, 'badge.manualReview'), desc: t(locale, 'badge.manualReviewDesc') },
              { title: t(locale, 'badge.coreTaskVerified'), desc: t(locale, 'badge.coreTaskVerifiedDesc') },
              { title: t(locale, 'badge.healthMonitoring'), desc: t(locale, 'badge.healthMonitoringDesc') },
              { title: t(locale, 'badge.digitalPreservation'), desc: t(locale, 'badge.digitalPreservationDesc') },
            ].map(item => (
              <li class="flex items-start gap-3">
                <svg class="mt-0.5 shrink-0 text-green-500" width="16" height="16" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                </svg>
                <div>
                  <p class="text-sm font-semibold text-neutral-900">{item.title}</p>
                  <p class="text-xs text-neutral-500 mt-0.5 leading-relaxed">{item.desc}</p>
                </div>
              </li>
            ))}
          </ul>
        </section>

        <!-- For Creators -->
        <section class="border rounded-lg p-6">
          <h2 class="text-lg font-bold text-neutral-900 mb-4 flex items-center gap-2">
            <span class="w-6 h-6 rounded bg-blue-100 flex items-center justify-center text-blue-600 text-xs font-bold">C</span>
            {t(locale, 'badge.joinTitle')}
          </h2>
          <p class="text-sm text-neutral-600 leading-relaxed mb-6">
            {t(locale, 'badge.joinDesc')}
          </p>
          <div class="space-y-4">
            {[t(locale, 'badge.step1'), t(locale, 'badge.step2'), t(locale, 'badge.step3'), t(locale, 'badge.step4')].map((step, i) => (
              <div class="flex items-center gap-3">
                 <div class="w-8 h-8 rounded bg-neutral-50 border border-neutral-200 flex items-center justify-center text-neutral-400 text-sm font-bold">{i + 1}</div>
                 <p class="text-sm font-semibold text-neutral-700">{step}</p>
              </div>
            ))}
          </div>
        </section>
      </div>

      <!-- Ranking Boost -->
      <section class="border-t pt-8 mt-8">
        <h2 class="text-xl font-bold text-neutral-900 mb-2 text-center">{t(locale, 'badge.rankingBoostTitle')}</h2>
        <p class="text-neutral-500 mb-8 max-w-xl mx-auto text-center text-sm">
          {t(locale, 'badge.rankingBoostDesc')}
        </p>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          <div class="p-5 border rounded-lg text-center">
            <p class="font-bold text-neutral-900 mb-1 text-sm uppercase tracking-tight">{t(locale, 'badge.svgBadge')}</p>
            <p class="text-green-600 font-bold text-2xl">+10</p>
            <p class="text-[10px] text-neutral-400 uppercase tracking-widest font-semibold mt-1">{t(locale, 'badge.rankPoints')}</p>
          </div>

          <div class="p-5 border rounded-lg text-center">
            <p class="font-bold text-neutral-900 mb-1 text-sm uppercase tracking-tight">{t(locale, 'badge.metaLink')}</p>
            <p class="text-blue-600 font-bold text-2xl">+5</p>
            <p class="text-[10px] text-neutral-400 uppercase tracking-widest font-semibold mt-1">{t(locale, 'badge.rankPoints')}</p>
          </div>

          <div class="p-5 border rounded-lg text-center">
            <p class="font-bold text-neutral-900 mb-1 text-sm uppercase tracking-tight">{t(locale, 'badge.noBadge')}</p>
            <p class="text-neutral-400 font-bold text-2xl">0</p>
            <p class="text-[10px] text-neutral-400 uppercase tracking-widest font-semibold mt-1">{t(locale, 'badge.rankPoints')}</p>
          </div>
        </div>
      </section>

      <!-- CTA -->
      <div class="text-center pt-4">
        <a href={getLocalizedPath('/submit', locale)} class="btn-minimal-primary">
          {t(locale, 'badge.submitYourTool')}
        </a>
      </div>
    </div>
  </div>
</Layout>
