---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { t, loadTranslations, getLocalizedPath } from '../i18n/utils';
import type { Locale } from '../i18n/config';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
await loadTranslations(locale);

const allPosts = await getCollection('blog');

// Filter by locale: root-level posts are English, posts in locale subdirs match that locale
const posts = allPosts
  .filter((post) => {
    if (locale === 'en') {
      // English: only root-level posts (no slash in id)
      return !post.id.includes('/');
    }
    // Other locales: posts in {locale}/ subdirectory
    return post.id.startsWith(`${locale}/`);
  })
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

// If no posts for this locale, fall back to English
const isFallback = posts.length === 0;
const displayPosts = !isFallback
  ? posts
  : allPosts
      .filter((post) => !post.id.includes('/'))
      .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());
// When falling back to English posts, links should use English paths (no locale prefix)
const linkLocale = isFallback ? 'en' as const : locale;

function formatDate(date: Date): string {
  return date.toISOString().split('T')[0];
}

const blogLd = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: 'nologin.tools Blog',
  url: `https://nologin.tools${getLocalizedPath('/blog', locale)}`,
  description: t(locale, 'blog.description'),
  inLanguage: locale,
  blogPost: displayPosts.map((post) => ({
    '@type': 'BlogPosting',
    headline: post.data.title,
    description: post.data.description,
    datePublished: formatDate(post.data.publishedAt),
    ...(post.data.updatedAt ? { dateModified: formatDate(post.data.updatedAt) } : {}),
    url: `https://nologin.tools${getLocalizedPath(`/blog/${getPostSlug(post.id)}`, linkLocale)}`,
    author: {
      '@type': 'Organization',
      name: post.data.author,
    },
  })),
};

function getPostSlug(postId: string): string {
  // For locale posts like "zh/welcome", strip the locale prefix
  return postId.includes('/') ? postId.split('/').slice(1).join('/') : postId;
}

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: t(locale, 'common.home'), item: `https://nologin.tools${getLocalizedPath('/', locale)}` },
    { '@type': 'ListItem', position: 2, name: t(locale, 'blog.title'), item: `https://nologin.tools${getLocalizedPath('/blog', locale)}` },
  ],
};
---

<Layout
  title={t(locale, 'blog.title')}
  description={t(locale, 'blog.description')}
  locale={locale}
>
  <script type="application/ld+json" set:html={JSON.stringify(blogLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />

  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-12 sm:py-20">
    <!-- Breadcrumb -->
    <nav aria-label="Breadcrumb" class="mb-8">
      <ol class="flex items-center gap-2 text-sm font-bold text-neutral-400">
        <li>
          <a href={getLocalizedPath('/', locale)} class="hover:text-neutral-900 transition-colors">{t(locale, 'common.home')}</a>
        </li>
        <li aria-hidden="true">
          <svg class="w-4 h-4 text-neutral-300" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd" /></svg>
        </li>
        <li aria-current="page" class="text-neutral-900">{t(locale, 'blog.title')}</li>
      </ol>
    </nav>

    <header class="mb-12 border-b-4 border-neutral-900 pb-6">
      <h1 class="text-3xl sm:text-4xl font-black text-neutral-900 tracking-tight uppercase italic">
        {t(locale, 'blog.heading')}
      </h1>
      <p class="text-base text-neutral-600 mt-3">
        {t(locale, 'blog.subtitle')}
      </p>
    </header>

    {displayPosts.length === 0 ? (
      <p class="text-neutral-500">{t(locale, 'blog.noPosts')}</p>
    ) : (
      <ul class="divide-y divide-neutral-200">
        {displayPosts.map((post) => (
          <li class="py-6 first:pt-0">
            <a href={getLocalizedPath(`/blog/${getPostSlug(post.id)}`, linkLocale)} class="group block">
              <div class="flex flex-col sm:flex-row sm:items-baseline sm:gap-4">
                <time
                  datetime={formatDate(post.data.publishedAt)}
                  class="text-xs text-neutral-400 font-mono shrink-0"
                >
                  {formatDate(post.data.publishedAt)}
                </time>
                <h2 class="text-lg font-bold text-neutral-900 group-hover:underline decoration-2 underline-offset-4">
                  {post.data.title}
                </h2>
              </div>
              <p class="text-sm text-neutral-600 mt-2 sm:ml-[calc(10ch+1rem)]">
                {post.data.description}
              </p>
            </a>
          </li>
        ))}
      </ul>
    )}
  </div>
</Layout>
