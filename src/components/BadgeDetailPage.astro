---
import Layout from '../layouts/Layout.astro';
import HealthBadge from './HealthBadge.astro';
import { formatDate } from '../lib/utils';
import { getBadgeEmbedCode, BADGE_STYLES, BADGE_GROUPS, ORIGINAL_BADGE } from '../lib/badge';
import { sortTagsCategoryFirst } from '../lib/tags';
import { DEFAULT_LOCALE, type Locale } from '../i18n/config';
import { t, loadTranslations, getLocalizedPath } from '../i18n/utils';

interface Props {
  tool: {
    id: number;
    slug: string;
    name: string;
    url: string;
    coreTask: string;
    status: string;
    approvedAt: Date | string | null;
  };
  toolTags: { tagKey: string; tagValue: string }[];
  latestHealth: { isOnline: boolean; checkedAt: Date } | null;
  slug: string;
  siteUrl: string;
  locale?: Locale;
}

const { tool, toolTags, latestHealth, slug, siteUrl, locale = DEFAULT_LOCALE } = Astro.props;
await loadTranslations(locale);

const isPending = tool.status === 'pending';

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: t(locale, 'common.home'), item: `https://nologin.tools${getLocalizedPath('/', locale)}` },
    { '@type': 'ListItem', position: 2, name: tool.name, item: `https://nologin.tools${getLocalizedPath(`/tool/${slug}`, locale)}` },
    { '@type': 'ListItem', position: 3, name: isPending ? t(locale, 'badgeDetail.pendingVerification') : t(locale, 'badgeDetail.verifiedTitle'), item: `https://nologin.tools${getLocalizedPath(`/badge/${slug}`, locale)}` },
  ],
};

const embedCode = getBadgeEmbedCode(slug, siteUrl, 'flat');
const allEmbedCodes = Object.fromEntries(
  [...BADGE_STYLES, ORIGINAL_BADGE].map((s) => [s.id, getBadgeEmbedCode(slug, siteUrl, s.id)])
);
---

<Layout
  bare
  title={`${tool.name} — ${isPending ? t(locale, 'badgeDetail.pendingVerification') : t(locale, 'badgeDetail.verifiedTitle')}`}
  description={isPending ? `${tool.name} is pending verification.` : `${tool.name} is NoLogin Verified. ${tool.coreTask}`}
  canonicalOverride={`/badge/${slug}`}
  locale={locale}
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />

  <div class="max-w-4xl mx-auto px-6 py-12 sm:py-16">
    <!-- Breadcrumb -->
    <nav aria-label="Breadcrumb" class="mb-8">
      <ol class="flex items-center gap-2 text-sm font-bold text-neutral-400">
        <li>
          <a href={getLocalizedPath('/', locale)} class="hover:text-neutral-900 transition-colors">{t(locale, 'common.home')}</a>
        </li>
        <li aria-hidden="true">
          <svg class="w-4 h-4 text-neutral-300" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd" /></svg>
        </li>
        <li>
          <a href={getLocalizedPath(`/tool/${slug}`, locale)} class="hover:text-neutral-900 transition-colors truncate max-w-[150px] sm:max-w-none inline-block">{tool.name}</a>
        </li>
        <li aria-hidden="true">
          <svg class="w-4 h-4 text-neutral-300" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd" /></svg>
        </li>
        <li aria-current="page" class="text-neutral-900">{isPending ? t(locale, 'badgeDetail.pendingVerification') : t(locale, 'badgeDetail.verifiedTitle')}</li>
      </ol>
    </nav>

    <!-- Badge brand link -->
    <div class="mb-12 flex justify-center">
      <a href="/" class="flex items-center gap-2 group">
        <div class="w-8 h-8 bg-green-600 rounded-lg flex items-center justify-center text-white font-black text-xl">
          n
        </div>
        <span class="font-black text-xl tracking-tight text-neutral-900">
          nologin<span class="text-green-600">.</span>tools
        </span>
      </a>
      <p class="text-xs text-neutral-400 mt-1 font-medium">by <a href="https://nologintools.org" target="_blank" rel="noopener noreferrer" class="hover:text-neutral-600 transition-colors">NoLoginTools.org</a></p>
    </div>

    <!-- Tab navigation -->
    <div class="flex items-center justify-center mb-12">
      <div class="inline-flex p-1 bg-neutral-100/50 rounded-2xl border border-neutral-200/50" role="tablist">
        <button role="tab" aria-selected="true" aria-controls="panel-verification"
          id="tab-verification"
          class="tab-btn px-8 py-2.5 text-sm font-black rounded-xl transition-all duration-300 border-none outline-none ring-0 cursor-pointer
                 aria-selected:bg-white aria-selected:text-neutral-900 aria-selected:shadow-sm aria-selected:ring-1 aria-selected:ring-neutral-200
                 text-neutral-400 hover:text-neutral-600">
          {t(locale, 'badgeDetail.verificationTab')}
        </button>
        <button role="tab" aria-selected="false" aria-controls="panel-embed"
          id="tab-embed"
          class="tab-btn px-8 py-2.5 text-sm font-black rounded-xl transition-all duration-300 border-none outline-none ring-0 cursor-pointer
                 aria-selected:bg-white aria-selected:text-neutral-900 aria-selected:shadow-sm aria-selected:ring-1 aria-selected:ring-neutral-200
                 text-neutral-400 hover:text-neutral-600">
          {t(locale, 'badgeDetail.embedTab')}
        </button>
      </div>
    </div>

    <!-- Panel: Verification (default visible) -->
    <div id="panel-verification" role="tabpanel" aria-labelledby="tab-verification" class="space-y-12">

      <!-- Certificate Hero -->
      <div class="text-center">
        <div class="inline-block mb-8">
          <div class:list={[
            "w-24 h-24 rounded-[2.5rem] flex items-center justify-center border-2",
            isPending ? "bg-amber-50 border-amber-200 text-amber-600" : "bg-green-50 border-green-200 text-green-600"
          ]}>
            {isPending ? (
              <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
            ) : (
              <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
            )}
          </div>
        </div>
        <h1 class:list={['text-4xl font-black tracking-tight', isPending ? 'text-amber-600' : 'text-green-600']}>
          {isPending ? t(locale, 'badgeDetail.pendingTitle') : t(locale, 'badgeDetail.verifiedTitle')}
        </h1>
        <p class="text-lg text-neutral-400 mt-2 font-medium">{t(locale, 'badgeDetail.certificate')} <span class="text-neutral-900 font-bold">{tool.name}</span></p>
      </div>

      <!-- Certificate Details Card -->
      <div class:list={[
        'bg-white border rounded-lg p-8 sm:p-12',
        isPending ? 'border-amber-200' : 'border-green-200',
      ]}>
        <h2 class="text-sm font-medium text-neutral-500 mb-10">{t(locale, 'badgeDetail.detailsTitle')}</h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-8">
          <div class="space-y-1">
            <dt class="text-sm font-medium text-neutral-500">{t(locale, 'badgeDetail.toolName')}</dt>
            <dd class="text-xl font-black text-neutral-950">{tool.name}</dd>
          </div>
          <div class="space-y-1">
            <dt class="text-sm font-medium text-neutral-500">{t(locale, 'badgeDetail.status')}</dt>
            <dd>
              <span class:list={['status-badge px-4 py-1.5 rounded-xl font-black uppercase tracking-tight text-[10px]', isPending ? 'status-pending' : 'status-approved']}>
                {isPending ? t(locale, 'badgeDetail.reviewInProgress') : t(locale, 'badgeDetail.verifiedApproved')}
              </span>
            </dd>
          </div>
          <div class="space-y-1">
            <dt class="text-sm font-medium text-neutral-500">{t(locale, 'badgeDetail.issuedBy')}</dt>
            <dd class="text-lg font-bold text-neutral-700"><a href="https://nologintools.org" target="_blank" rel="noopener noreferrer" class="text-green-600 hover:text-green-700 transition-colors">NoLoginTools.org</a></dd>
          </div>
          <div class="space-y-1 md:col-span-2">
            <dt class="text-sm font-medium text-neutral-500">{t(locale, 'badgeDetail.toolUrl')}</dt>
            <dd>
              <a href={tool.url} target="_blank" rel="noopener noreferrer" class="text-lg font-bold text-blue-600 hover:text-blue-700 break-all underline decoration-blue-200 underline-offset-4">{tool.url}</a>
            </dd>
          </div>
          <div class="space-y-1 md:col-span-2">
            <dt class="text-sm font-medium text-neutral-500">{t(locale, 'badgeDetail.certifiedCoreTask')}</dt>
            <dd class="text-lg font-bold text-neutral-700 leading-relaxed italic">"{tool.coreTask}"</dd>
          </div>

          {!isPending && tool.approvedAt && (
            <div class="space-y-1">
              <dt class="text-sm font-medium text-neutral-500">{t(locale, 'badgeDetail.verifiedSince')}</dt>
              <dd class="text-lg font-bold text-neutral-700">{formatDate(tool.approvedAt)}</dd>
            </div>
          )}
          {!isPending && (
            <div class="space-y-1">
              <dt class="text-sm font-medium text-neutral-500">{t(locale, 'badgeDetail.currentHealth')}</dt>
              <dd>
                <HealthBadge
                  isOnline={latestHealth?.isOnline ?? null}
                  locale={locale}
                  lastCheckedAt={latestHealth?.checkedAt ?? null}
                />
              </dd>
            </div>
          )}
        </div>

        {toolTags.length > 0 && (
          <div class="mt-12 pt-8 border-t border-neutral-200">
            <dt class="text-sm font-medium text-neutral-500 mb-4">{t(locale, 'badgeDetail.classifications')}</dt>
            <div class="flex flex-wrap gap-2">
              {sortTagsCategoryFirst(toolTags).map((tag) => (
                <span class:list={['chip px-4 py-1.5 font-bold uppercase tracking-wider text-[10px]', tag.tagKey === 'category' ? 'chip-category' : 'chip-default']}>
                  {tag.tagKey === 'category' ? tag.tagValue : tag.tagValue}
                </span>
              ))}
            </div>
          </div>
        )}
      </div>

      <!-- Quick Intro for External Visitors -->
      <div class="border-l-4 border-green-500 pl-6 py-4">
        <div class="flex flex-col md:flex-row items-start gap-6">
          <div class="w-10 h-10 shrink-0 rounded-lg bg-green-50 flex items-center justify-center text-green-600">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
          </div>
          <div>
            <h2 class="text-lg font-bold text-neutral-900 mb-1">{t(locale, 'badgeDetail.whatIsTitle')}</h2>
            <p class="text-neutral-600 text-sm leading-relaxed">
              This certificate, issued by <a href="https://nologintools.org" target="_blank" rel="noopener noreferrer" class="text-green-600 font-semibold hover:text-green-700 transition-colors">NoLoginTools.org</a>, confirms that <span class="font-semibold">{tool.name}</span> has been manually audited. It guarantees that users can access its core features <strong>immediately</strong>—without ever needing to sign up or log in.
            </p>
          </div>
        </div>
      </div>

      <!-- Trust Signals Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        {[
          { title: t(locale, 'badgeDetail.trustManualReview'), desc: t(locale, 'badgeDetail.trustManualReviewDesc'), icon: "M" },
          { title: t(locale, 'badgeDetail.trustPrivacy'), desc: t(locale, 'badgeDetail.trustPrivacyDesc'), icon: "P" },
          { title: t(locale, 'badgeDetail.trustMonitoring'), desc: t(locale, 'badgeDetail.trustMonitoringDesc'), icon: "H" },
          { title: t(locale, 'badgeDetail.trustArchive'), desc: t(locale, 'badgeDetail.trustArchiveDesc'), icon: "A" }
        ].map(item => (
          <div class="border border-neutral-200 rounded-lg p-5 flex gap-4">
            <div class="w-10 h-10 rounded-lg bg-green-50 flex items-center justify-center text-green-600 font-black shrink-0 border border-green-100">
               {item.icon}
            </div>
            <div>
              <h3 class="text-sm font-bold text-neutral-900">{item.title}</h3>
              <p class="text-xs text-neutral-500 mt-1 leading-relaxed">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>

      <!-- Actions -->
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a href={tool.url} target="_blank" rel="noopener noreferrer" class="btn-minimal-primary px-8 py-3 rounded-lg font-semibold">{t(locale, 'badgeDetail.visitTool')}</a>
        <a href={getLocalizedPath(`/tool/${slug}`, locale)} class="inline-flex items-center justify-center text-sm font-medium text-neutral-600 underline underline-offset-4 decoration-neutral-300 hover:text-neutral-900 hover:decoration-neutral-500 transition-colors px-8 py-3">{t(locale, 'badgeDetail.directoryListing')}</a>
      </div>

      <!-- Bottom attribution -->
      <p class="text-center text-xs text-neutral-400 font-medium">
        This certificate is issued and maintained by <a href="https://nologintools.org" target="_blank" rel="noopener noreferrer" class="text-neutral-500 hover:text-neutral-700 transition-colors">NoLoginTools.org</a>
      </p>
    </div> <!-- end panel-verification -->

    <!-- Panel: Embed Code (hidden by default) -->
    <div id="panel-embed" role="tabpanel" aria-labelledby="tab-embed" class="hidden space-y-12">

      <section class="border border-neutral-200 rounded-lg p-8 sm:p-12 text-center">
        <h2 class="text-3xl font-black text-neutral-900 mb-4">{t(locale, 'badgeDetail.addToSite')}</h2>
        <p class="text-neutral-500 max-w-xl mx-auto font-medium mb-10">
          Display the NoLogin Verified badge to signal your commitment to a frictionless user experience.
          Tools with active badges receive a ranking boost.
        </p>

        {isPending && (
          <div class="bg-amber-50 border border-amber-200 rounded-lg p-6 mb-10 max-w-2xl mx-auto">
            <p class="text-sm text-amber-800 font-bold">
              Verification in progress. You can embed the code now; it will automatically update to "Verified" once approved.
            </p>
          </div>
        )}

        <!-- Badge Style Selector -->
        <div class="mb-12 text-left">
          <h3 class="text-sm font-medium text-neutral-500 mb-8 text-center">{t(locale, 'badgeDetail.customizeStyle')}</h3>
          <div class="space-y-10">
            {BADGE_GROUPS.map((group) => {
              const groupStyles = BADGE_STYLES.filter((s) => s.group === group.id);
              const isDark = group.id === 'dark';
              return groupStyles.length > 0 && (
                <div>
                  <p class="text-xs font-medium text-neutral-400 mb-4 text-center">{group.label} Collection</p>
                  <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
                    {groupStyles.map((style) => (
                      <button
                        class:list={[
                          'badge-style-btn flex flex-col items-center justify-center gap-4 border rounded p-3 transition-all duration-200 cursor-pointer',
                          isDark ? 'bg-neutral-900 border-neutral-800' : 'bg-white border-neutral-200',
                          style.id === 'flat'
                            ? 'ring-2 ring-green-500 border-transparent'
                            : 'hover:border-neutral-400',
                        ]}
                        data-style={style.id}
                        data-badge-path={style.path}
                        data-dark={isDark ? 'true' : undefined}
                      >
                        <img src={style.path} alt={style.label} class="h-6" />
                        <span class:list={['text-xs font-medium', isDark ? 'text-neutral-500' : 'text-neutral-400']}>{style.label}</span>
                      </button>
                    ))}
                  </div>
                </div>
              );
            })}
          </div>
        </div>

        <!-- Code Displays -->
        <div class="grid grid-cols-1 gap-8 text-left max-w-3xl mx-auto">
          <!-- SVG Badge -->
          <div class="space-y-3">
            <div class="flex items-center justify-between">
              <h3 class="text-sm font-medium text-neutral-500">{t(locale, 'badgeDetail.svgRecommended')}</h3>
              <button class="copy-btn text-xs font-medium text-green-600 hover:text-green-700 px-3 py-1 rounded bg-green-50 transition-colors" data-code="svg">Copy Code</button>
            </div>
            <div class="p-6 bg-white border border-neutral-200 rounded-lg flex justify-center mb-4">
              <img id="badge-preview" src="/badges/flat.svg" alt="NoLogin Verified" class="h-10" />
            </div>
            <pre id="code-svg" class="bg-neutral-900 text-neutral-400 p-6 rounded-lg text-[11px] font-mono overflow-x-auto border border-neutral-800"><code>{embedCode.svg}</code></pre>
          </div>

          <!-- Meta tag -->
          <div class="space-y-3">
             <div class="flex items-center justify-between">
              <h3 class="text-sm font-medium text-neutral-500">{t(locale, 'badgeDetail.metaTag')}</h3>
              <button class="copy-btn text-xs font-medium text-green-600 hover:text-green-700 px-3 py-1 rounded bg-green-50 transition-colors" data-code="meta">Copy Code</button>
            </div>
            <pre id="code-meta" class="bg-neutral-900 text-neutral-400 p-6 rounded-lg text-[11px] font-mono overflow-x-auto border border-neutral-800"><code>{embedCode.meta}</code></pre>
          </div>
        </div>
      </section>

    </div> <!-- end panel-embed -->

    <script id="embed-codes-data" type="application/json" set:html={JSON.stringify(allEmbedCodes)} />
  </div>

  <script>
    // Tab switching
    const tabs = {
      verification: {
        btn: document.getElementById('tab-verification')!,
        panel: document.getElementById('panel-verification')!,
      },
      embed: {
        btn: document.getElementById('tab-embed')!,
        panel: document.getElementById('panel-embed')!,
      },
    };

    function activateTab(name: 'verification' | 'embed') {
      for (const [key, { btn, panel }] of Object.entries(tabs)) {
        const isActive = key === name;
        panel.classList.toggle('hidden', !isActive);
        btn.setAttribute('aria-selected', String(isActive));
        btn.classList.toggle('border-green-500', isActive);
        btn.classList.toggle('text-green-600', isActive);
        btn.classList.toggle('border-transparent', !isActive);
        btn.classList.toggle('text-neutral-500', !isActive);
      }
    }

    // Initialize from hash
    if (window.location.hash === '#embed') {
      activateTab('embed');
    }

    // Tab click handlers
    tabs.verification.btn.addEventListener('click', () => {
      activateTab('verification');
      history.replaceState(null, '', window.location.pathname);
    });

    tabs.embed.btn.addEventListener('click', () => {
      activateTab('embed');
      history.replaceState(null, '', '#embed');
    });

    // Handle browser back/forward
    window.addEventListener('hashchange', () => {
      activateTab(window.location.hash === '#embed' ? 'embed' : 'verification');
    });

    // Badge style switching
    const embedCodes: Record<string, { svg: string }> = JSON.parse(
      document.getElementById('embed-codes-data')!.textContent!
    );
    const styleBtns = document.querySelectorAll('.badge-style-btn');
    const badgePreview = document.getElementById('badge-preview') as HTMLImageElement;
    const codeSvg = document.getElementById('code-svg');

    styleBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const style = (btn as HTMLElement).dataset.style!;
        const badgePath = (btn as HTMLElement).dataset.badgePath!;

        // Update preview image
        badgePreview.src = badgePath;

        // Update SVG embed code
        if (codeSvg && embedCodes[style]) {
          codeSvg.innerHTML = `<code>${embedCodes[style].svg.replace(/</g, '&lt;').replace(/>/g, '&gt;')}</code>`;
        }

        // Update button styles
        styleBtns.forEach((b) => {
          const el = b as HTMLElement;
          const isDark = el.dataset.dark === 'true';
          if (el.dataset.style === style) {
            el.classList.add('ring-2', 'ring-green-500', 'border-transparent');
            el.classList.remove('border-neutral-200', 'border-neutral-800', 'hover:border-neutral-400');
            if (!isDark) el.classList.add('bg-green-50');
          } else {
            el.classList.remove('ring-2', 'ring-green-500', 'border-transparent', 'bg-green-50');
            el.classList.add('hover:border-neutral-400');
            if (isDark) {
              el.classList.add('border-neutral-800');
            } else {
              el.classList.add('border-neutral-200');
            }
          }
        });
      });
    });

    // Copy to clipboard
    document.querySelectorAll('.copy-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const codeId = `code-${(btn as HTMLElement).dataset.code}`;
        const codeEl = document.getElementById(codeId);
        if (codeEl) {
          navigator.clipboard.writeText(codeEl.textContent || '');
          btn.textContent = 'Copied!';
          setTimeout(() => {
            btn.textContent = 'Copy';
          }, 2000);
        }
      });
    });
  </script>
</Layout>
