---
import Layout from '../layouts/Layout.astro';
import { t, loadTranslations, getLocalizedPath } from '../i18n/utils';
import type { Locale } from '../i18n/config';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
await loadTranslations(locale);
---

<Layout title={t(locale, 'notFound.title')} description={t(locale, 'notFound.description')} locale={locale}>
  <div class="max-w-4xl mx-auto px-6 py-24 text-center">
    <h1 class="text-6xl font-bold text-neutral-200 mb-6">{t(locale, 'notFound.heading')}</h1>
    <p class="text-lg text-neutral-600 mb-2">{t(locale, 'notFound.message')}</p>
    <p class="text-sm text-neutral-400 mb-8">
      {t(locale, 'notFound.detail')}
    </p>
    <a href={getLocalizedPath('/', locale)} class="text-sm font-medium text-green-600 hover:text-green-700 underline underline-offset-4">
      {t(locale, 'notFound.backHome')}
    </a>
  </div>
</Layout>
