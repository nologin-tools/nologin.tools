---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import { getBadgeEmbedCode, BADGE_STYLES, BADGE_GROUPS, ORIGINAL_BADGE } from '../../lib/badge';

const slug = Astro.url.searchParams.get('slug') || '';
const siteUrl = Astro.locals.runtime.env.SITE_URL || 'https://nologin.tools';
const embedCode = getBadgeEmbedCode(slug, siteUrl, 'flat');
const allEmbedCodes = Object.fromEntries(
  [...BADGE_STYLES, ORIGINAL_BADGE].map((s) => [s.id, getBadgeEmbedCode(slug, siteUrl, s.id)])
);
---

<Layout
  title="Tool Submitted"
  description="Your tool has been submitted for review."
>
  <div class="max-w-4xl mx-auto px-6 py-16 sm:py-24">
    <!-- Success message -->
    <div class="text-center mb-16">
      <span class="text-green-500 text-3xl mb-4 inline-block">&#10003;</span>
      <h1 class="text-2xl font-bold tracking-tight text-neutral-900 mb-4">
        Submission Received!
      </h1>
      <p class="text-neutral-500 max-w-xl mx-auto leading-relaxed">
        Thank you for contributing to the community. Our team will review your submission shortly.
      </p>
    </div>

    <div class="space-y-12">
      <!-- Tool page link -->
      {slug && (
        <section class="border-b pb-6 mb-6">
          <h2 class="text-sm font-medium text-neutral-500 mb-4">Pending Tool Page</h2>
          <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
            <div>
              <p class="text-neutral-900 font-bold mb-1">Preview your listing</p>
              <a href={`/tool/${slug}`} class="text-blue-600 hover:underline break-all">{siteUrl}/tool/{slug}</a>
            </div>
            <a href={`/tool/${slug}`} class="text-blue-600 hover:underline whitespace-nowrap">View Page &rarr;</a>
          </div>
          <p class="text-xs text-neutral-400 mt-4">
            Note: The tool will only appear in the public directory and search results after it has been approved.
          </p>
        </section>
      )}

      <!-- Badge integration guide -->
      <section class="border-t pt-8">
        <div class="text-center mb-10">
          <h2 class="text-xl font-bold text-neutral-900 mb-3">Get the Badge Ready</h2>
          <p class="text-neutral-500 max-w-xl mx-auto">
            While you wait for approval, you can prepare the verification badge for your website.
            Tools that display the badge receive higher visibility.
          </p>
        </div>

        <!-- Badge Style Selector -->
        <div class="mb-10">
          <h3 class="text-sm font-medium text-neutral-500 mb-6 text-center">Select Your Preferred Style</h3>
          <div class="space-y-8">
            {BADGE_GROUPS.map((group) => {
              const groupStyles = BADGE_STYLES.filter((s) => s.group === group.id);
              const isDark = group.id === 'dark';
              return groupStyles.length > 0 && (
                <div>
                  <p class="text-sm font-medium text-neutral-500 mb-3 text-center">{group.label}</p>
                  <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
                    {groupStyles.map((style) => (
                      <button
                        class:list={[
                          'badge-style-btn flex flex-col items-center justify-center gap-3 p-3 rounded border transition-all duration-200 cursor-pointer',
                          isDark ? 'bg-neutral-900 border-neutral-800' : 'bg-white border-neutral-200',
                          style.id === 'flat'
                            ? 'ring-2 ring-green-500 border-transparent'
                            : 'hover:border-neutral-300',
                        ]}
                        data-style={style.id}
                        data-badge-path={style.path}
                        data-dark={isDark ? 'true' : undefined}
                      >
                        <img src={style.path} alt={style.label} class="h-6" />
                        <span class:list={['text-xs text-neutral-400', isDark ? 'text-neutral-500' : '']}>{style.label}</span>
                      </button>
                    ))}
                  </div>
                </div>
              );
            })}
          </div>
        </div>

        <div class="grid grid-cols-1 gap-8 text-left max-w-2xl mx-auto">
          <!-- SVG Badge -->
          <div class="space-y-3">
            <div class="flex items-center justify-between">
              <h3 class="text-sm font-medium text-neutral-500">SVG Badge</h3>
              <button class="copy-btn text-xs font-medium text-green-600 hover:text-green-700 px-3 py-1 rounded bg-green-50 transition-colors" data-code="svg">Copy</button>
            </div>
            <div class="p-4 bg-white border border-neutral-200 rounded flex justify-center mb-3">
              <img id="badge-preview" src="/badges/flat.svg" alt="NoLogin Verified" class="h-10" />
            </div>
            <pre id="code-svg" class="bg-neutral-900 text-neutral-400 p-4 rounded text-[11px] font-mono overflow-x-auto"><code>{embedCode.svg}</code></pre>
          </div>

          <!-- Meta tag -->
          <div class="space-y-3">
             <div class="flex items-center justify-between">
              <h3 class="text-sm font-medium text-neutral-500">Meta Tag</h3>
              <button class="copy-btn text-xs font-medium text-green-600 hover:text-green-700 px-3 py-1 rounded bg-green-50 transition-colors" data-code="meta">Copy</button>
            </div>
            <pre id="code-meta" class="bg-neutral-900 text-neutral-400 p-4 rounded text-[11px] font-mono overflow-x-auto"><code>{embedCode.meta}</code></pre>
          </div>
        </div>
      </section>

      <div class="text-center pt-8">
        <a href="/" class="btn-minimal-primary">
          Back to Directory
        </a>
      </div>
    </div>
  </div>

  <script id="embed-codes-data" type="application/json" set:html={JSON.stringify(allEmbedCodes)} />

  <script>
    // Badge style switching
    const embedCodes: Record<string, { svg: string }> = JSON.parse(
      document.getElementById('embed-codes-data')!.textContent!
    );
    const styleBtns = document.querySelectorAll('.badge-style-btn');
    const badgePreview = document.getElementById('badge-preview') as HTMLImageElement;
    const codeSvg = document.getElementById('code-svg');

    styleBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const style = (btn as HTMLElement).dataset.style!;
        const badgePath = (btn as HTMLElement).dataset.badgePath!;

        badgePreview.src = badgePath;

        if (codeSvg && embedCodes[style]) {
          codeSvg.innerHTML = `<code>${embedCodes[style].svg.replace(/</g, '&lt;').replace(/>/g, '&gt;')}</code>`;
        }

        styleBtns.forEach((b) => {
          const el = b as HTMLElement;
          const isDark = el.dataset.dark === 'true';
          if (el.dataset.style === style) {
            el.classList.add('ring-2', 'ring-green-500', 'border-transparent');
            el.classList.remove('border-neutral-200', 'border-neutral-800', 'hover:border-neutral-300');
          } else {
            el.classList.remove('ring-2', 'ring-green-500', 'border-transparent');
            el.classList.add('hover:border-neutral-300');
            if (isDark) {
              el.classList.add('border-neutral-800');
            } else {
              el.classList.add('border-neutral-200');
            }
          }
        });
      });
    });

    // Copy to clipboard
    document.querySelectorAll('.copy-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const codeId = `code-${(btn as HTMLElement).dataset.code}`;
        const codeEl = document.getElementById(codeId);
        if (codeEl) {
          navigator.clipboard.writeText(codeEl.textContent || '');
          btn.textContent = 'Copied!';
          setTimeout(() => {
            btn.textContent = 'Copy';
          }, 2000);
        }
      });
    });
  </script>
</Layout>
