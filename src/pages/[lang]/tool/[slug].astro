---
import {
  getAvailableToolLocales,
  getAllTools,
  getLocalizedDescription,
  getLocalizedTool,
  getRelatedTools,
} from '../../../data/loader';
import ToolDetailPage from '../../../components/ToolDetailPage.astro';
import { buildLocalizedToolStaticPaths } from '../../../lib/tool-seo.mjs';
import { LOCALES, DEFAULT_LOCALE, type Locale } from '../../../i18n/config';

export function getStaticPaths() {
  return buildLocalizedToolStaticPaths(
    getAllTools(),
    LOCALES,
    DEFAULT_LOCALE,
    (tool) => getAvailableToolLocales(tool)
  ).map((path) => ({
    ...path,
    props: { ...path.props, locale: path.props.locale as Locale },
  }));
}

const { tool, locale } = Astro.props;
const availableLocales = getAvailableToolLocales(tool);
const toolData = getLocalizedTool(tool, locale);

const toolTags = tool.tags.map((t: any) => ({
  tagKey: t.tagKey,
  tagValue: t.tagValue,
}));

const recentChecks = tool.healthChecks.map((c: any) => ({
  isOnline: c.isOnline,
  httpStatus: c.httpStatus,
  responseTimeMs: c.responseTimeMs,
  checkedAt: new Date(c.checkedAt),
}));

const healthHistory = tool.healthHistory.map((h: any) => ({
  isOnline: h.isOnline,
  checkedAt: new Date(h.checkedAt),
}));

const categoryTag = tool.tags.find((t: any) => t.tagKey === 'category')?.tagValue;
const related = getRelatedTools(tool.slug, categoryTag).map((rt) => ({
  slug: rt.slug,
  name: rt.name,
  url: rt.url,
  description: getLocalizedDescription(rt, locale),
}));
---

<ToolDetailPage
  tool={toolData}
  toolTags={toolTags}
  recentChecks={recentChecks}
  healthHistory={healthHistory}
  slug={tool.slug}
  locale={locale}
  availableLocales={availableLocales}
  relatedTools={related}
/>
