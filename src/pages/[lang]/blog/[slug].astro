---
import Layout from '../../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import { LOCALES, DEFAULT_LOCALE, type Locale } from '../../../i18n/config';
import { t, loadTranslations, getLocalizedPath } from '../../../i18n/utils';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const paths: any[] = [];

  for (const lang of LOCALES.filter(l => l !== DEFAULT_LOCALE)) {
    // For each language, get posts: translated version if exists, otherwise English
    const localePosts = posts.filter(p => p.id.startsWith(`${lang}/`));
    const englishPosts = posts.filter(p => !p.id.includes('/'));

    // Use locale-specific posts
    for (const post of localePosts) {
      const slug = post.id.split('/').slice(1).join('/');
      paths.push({
        params: { lang, slug },
        props: { post, locale: lang as Locale },
      });
    }

    // For English posts without a translated version, still generate the page
    for (const post of englishPosts) {
      const hasTranslation = localePosts.some(p => p.id === `${lang}/${post.id}`);
      if (!hasTranslation) {
        paths.push({
          params: { lang, slug: post.id },
          props: { post, locale: lang as Locale },
        });
      }
    }
  }

  return paths;
}

const { post, locale } = Astro.props;
await loadTranslations(locale);
const { Content } = await render(post);

function formatDate(date: Date): string {
  return date.toISOString().split('T')[0];
}

const publishedDate = formatDate(post.data.publishedAt);
const modifiedDate = post.data.updatedAt ? formatDate(post.data.updatedAt) : undefined;

// Hero image OG — use originalSlug for translated posts
const originalSlug = post.data.originalSlug || getPostSlug(post.id);
const heroImagePath = `/blog/images/${originalSlug}/hero.jpg`;
const hasHeroImage = !!post.data.heroImageQuery;
const ogImageForPost = hasHeroImage ? heroImagePath : '/og-default.png';

const allPosts = await getCollection('blog');
const related = allPosts
  .filter((p) => p.id !== post.id && p.data.tags.some((tag: string) => post.data.tags.includes(tag)))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
  .slice(0, 3);

function getPostSlug(postId: string): string {
  return postId.includes('/') ? postId.split('/').slice(1).join('/') : postId;
}

const wordCount = post.body ? post.body.trim().split(/\s+/).length : undefined;

const postLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  datePublished: publishedDate,
  ...(modifiedDate ? { dateModified: modifiedDate } : {}),
  url: `https://nologin.tools${getLocalizedPath(`/blog/${getPostSlug(post.id)}`, locale)}`,
  image: {
    '@type': 'ImageObject',
    url: `https://nologin.tools${ogImageForPost}`,
    width: 1200,
    height: 630,
  },
  inLanguage: locale,
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': `https://nologin.tools${getLocalizedPath(`/blog/${getPostSlug(post.id)}`, locale)}`,
  },
  ...(wordCount ? { wordCount } : {}),
  author: {
    '@type': 'Organization',
    name: post.data.author,
    url: 'https://nologin.tools',
  },
  publisher: {
    '@type': 'Organization',
    name: 'NoLoginTools.org',
    logo: {
      '@type': 'ImageObject',
      url: 'https://nologin.tools/og-default.png',
    },
  },
  ...(post.data.tags.length > 0 ? { keywords: post.data.tags.join(', ') } : {}),
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: t(locale, 'common.home'), item: `https://nologin.tools${getLocalizedPath('/', locale)}` },
    { '@type': 'ListItem', position: 2, name: t(locale, 'blog.title'), item: `https://nologin.tools${getLocalizedPath('/blog', locale)}` },
    { '@type': 'ListItem', position: 3, name: post.data.title, item: `https://nologin.tools${getLocalizedPath(`/blog/${getPostSlug(post.id)}`, locale)}` },
  ],
};
---

<Layout
  title={post.data.title}
  description={post.data.description}
  ogType="article"
  ogImage={ogImageForPost}
  publishedTime={publishedDate}
  modifiedTime={modifiedDate}
  articleTags={post.data.tags}
  locale={locale}
>
  <script type="application/ld+json" set:html={JSON.stringify(postLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />

  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-8 sm:py-12">
    <!-- Breadcrumb -->
    <nav aria-label="Breadcrumb" class="mb-8">
      <ol class="flex items-center gap-2 text-sm font-bold text-neutral-400">
        <li>
          <a href={getLocalizedPath('/', locale)} class="hover:text-neutral-900 transition-colors">{t(locale, 'common.home')}</a>
        </li>
        <li aria-hidden="true">
          <svg class="w-4 h-4 text-neutral-300" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd" /></svg>
        </li>
        <li>
          <a href={getLocalizedPath('/blog', locale)} class="hover:text-neutral-900 transition-colors">{t(locale, 'blog.title')}</a>
        </li>
        <li aria-hidden="true">
          <svg class="w-4 h-4 text-neutral-300" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd" /></svg>
        </li>
        <li aria-current="page" class="text-neutral-900 truncate max-w-[200px] sm:max-w-none">{post.data.title}</li>
      </ol>
    </nav>

    <!-- Article Header -->
    <header class="mb-10 border-b border-neutral-200 pb-8">
      <h1 class="text-2xl sm:text-3xl font-black text-neutral-900 tracking-tight mb-4">
        {post.data.title}
      </h1>
      <div class="flex flex-wrap items-center gap-3 text-sm text-neutral-400">
        <time datetime={publishedDate} class="font-mono">{publishedDate}</time>
        {modifiedDate && (
          <>
            <span class="text-neutral-300">·</span>
            <span>{t(locale, 'blog.updated', { date: modifiedDate })}</span>
          </>
        )}
        <span class="text-neutral-300">·</span>
        <span>{post.data.author}</span>
      </div>
      {post.data.tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-4">
          {post.data.tags.map((tag: string) => (
            <span class="text-xs font-mono text-neutral-500 border border-neutral-200 px-2 py-0.5">
              {tag}
            </span>
          ))}
        </div>
      )}
    </header>

    <!-- Article Content -->
    <article class="prose prose-neutral max-w-none">
      <Content />
    </article>

    <!-- Related Posts -->
    {related.length > 0 && (
      <aside class="mt-16 border-t border-neutral-200 pt-8">
        <h2 class="text-sm font-bold text-neutral-500 uppercase tracking-wider mb-6">{t(locale, 'blog.relatedPosts')}</h2>
        <ul class="space-y-4">
          {related.map((r) => (
            <li>
              <a href={getLocalizedPath(`/blog/${getPostSlug(r.id)}`, locale)} class="group flex items-baseline gap-3">
                <time datetime={formatDate(r.data.publishedAt)} class="text-xs text-neutral-400 font-mono shrink-0">
                  {formatDate(r.data.publishedAt)}
                </time>
                <span class="text-neutral-900 font-bold group-hover:underline decoration-2 underline-offset-4">
                  {r.data.title}
                </span>
              </a>
            </li>
          ))}
        </ul>
      </aside>
    )}
  </div>
</Layout>
