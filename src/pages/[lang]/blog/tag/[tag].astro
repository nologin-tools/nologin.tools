---
import BlogTagPage from '../../../../components/BlogTagPage.astro';
import { getCollection } from 'astro:content';
import { LOCALES, DEFAULT_LOCALE, type Locale } from '../../../../i18n/config';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const englishPosts = posts.filter((p) => !p.id.includes('/'));
  const allTags = new Set<string>();
  for (const post of englishPosts) {
    for (const tag of post.data.tags) {
      allTags.add(tag.toLowerCase());
    }
  }
  return LOCALES.filter((l) => l !== DEFAULT_LOCALE).flatMap((lang) =>
    [...allTags].map((tag) => ({
      params: { lang, tag },
      props: { tag, locale: lang as Locale },
    }))
  );
}

const { tag, locale } = Astro.props;
---

<BlogTagPage locale={locale} tag={tag} />
