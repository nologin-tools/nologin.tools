---
import Layout from '../layouts/Layout.astro';
import { TAG_DEFINITIONS } from '../lib/tags';
import { getApprovedTools, getToolHealthStatus, computeScore as computeToolScore } from '../data/loader';
import type { EffectiveStatus } from '../lib/health';

const approvedTools = getApprovedTools();

const toolsWithMeta = approvedTools.map(tool => {
  const health = getToolHealthStatus(tool);
  const score = computeToolScore(tool, health);
  return { ...tool, health, score };
});

const allTools = [...toolsWithMeta].sort((a, b) => b.score - a.score);

// Group tools by category
const categoryDef = TAG_DEFINITIONS.find(d => d.key === 'category');
const categoryOrder = categoryDef ? categoryDef.values : [];
type ToolType = (typeof allTools)[number];
const groupMap = new Map<string, ToolType[]>();
for (const cat of categoryOrder) groupMap.set(cat, []);

for (const tool of allTools) {
  const catTag = tool.tags.find(t => t.tagKey === 'category');
  const cat = catTag ? catTag.tagValue : 'Other';
  if (!groupMap.has(cat)) groupMap.set(cat, []);
  groupMap.get(cat)!.push(tool);
}

const categoryGroups: { category: string; tools: ToolType[] }[] = [];
for (const cat of categoryOrder) {
  const catTools = groupMap.get(cat) || [];
  if (catTools.length > 0) categoryGroups.push({ category: cat, tools: catTools });
}
const otherGroupTools = groupMap.get('Other') || [];
if (otherGroupTools.length > 0) categoryGroups.push({ category: 'Other', tools: otherGroupTools });

const totalTools = allTools.length;
const totalCategories = categoryGroups.length;

function getHostname(url: string): string {
  try { return new URL(url).hostname.replace(/^www\./, ''); } catch { return ''; }
}

function healthLabel(status: EffectiveStatus): { text: string; symbol: string; color: string } {
  switch (status) {
    case 'online': return { text: 'Online', symbol: '✓', color: 'text-green-600' };
    case 'unstable': return { text: 'Unstable', symbol: '⚠', color: 'text-amber-500' };
    case 'offline': return { text: 'Offline', symbol: '✗', color: 'text-red-500' };
  }
}

function catAnchor(cat: string): string {
  return 'cat-' + cat.toLowerCase().replace(/\s+/g, '-');
}
---

<Layout
  title="Privacy-Friendly Tools Without Login"
  description="Discover curated privacy-friendly tools that work without login or signup. Browse verified tools across design, development, productivity, and more."
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "nologin.tools",
    "url": "https://nologin.tools",
    "potentialAction": {
      "@type": "SearchAction",
      "target": "https://nologin.tools/?q={search_term_string}",
      "query-input": "required name=search_term_string"
    }
  })} />

  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-8 sm:py-14">
    <!-- Hero -->
    <div class="mb-10 sm:mb-14">
      <h1 class="text-2xl sm:text-3xl font-bold text-neutral-900 mb-2">nologin.tools</h1>
      <p class="text-neutral-500 mb-3">Privacy-friendly tools. No login required.</p>
      <p class="text-sm text-neutral-400 mb-3">
        {totalTools} verified tools across {totalCategories} categories
      </p>
      <p class="text-xs text-neutral-400" id="bookmark-hint">
        <span class="text-neutral-500">⌨</span> Press <kbd class="px-1.5 py-0.5 bg-neutral-100 border border-neutral-200 rounded text-[11px] font-mono" id="bookmark-key">Ctrl+D</kbd> to bookmark this page
      </p>
    </div>

    <!-- Category Navigation -->
    <nav class="mb-10 sm:mb-12 text-sm" aria-label="Category navigation">
      <div class="flex flex-wrap gap-x-1.5 gap-y-1 text-neutral-500">
        {categoryGroups.map((group, i) => (
          <>
            {i > 0 && <span class="text-neutral-300">·</span>}
            <a href={`#${catAnchor(group.category)}`} class="hover:text-neutral-900 transition-colors">
              {group.category}
            </a>
          </>
        ))}
      </div>
    </nav>

    <!-- Tool Lists by Category -->
    <div class="space-y-10 sm:space-y-12">
      {categoryGroups.map((group) => (
        <section id={catAnchor(group.category)}>
          <h2 class="category-heading">
            {group.category} <span class="font-normal text-neutral-400">({group.tools.length})</span>
          </h2>
          <ul class="divide-y divide-neutral-100">
            {group.tools.map((tool) => {
              const hostname = getHostname(tool.url);
              const health = tool.health;
              const hl = health ? healthLabel(health.status) : null;
              return (
                <li class="tool-item">
                  <div class="flex items-start sm:items-center gap-2 sm:gap-3 min-w-0 flex-1">
                    {/* Favicon */}
                    <img
                      src={`https://www.google.com/s2/favicons?domain=${hostname}&sz=32`}
                      alt=""
                      width="16"
                      height="16"
                      class="w-4 h-4 mt-0.5 sm:mt-0 shrink-0 rounded-sm"
                      loading="lazy"
                      onerror={`this.style.display='none'`}
                    />
                    <div class="min-w-0 flex flex-col sm:flex-row sm:items-center sm:gap-1.5 flex-1">
                      <div class="flex items-center gap-1.5 min-w-0">
                        {tool.isFeatured && (
                          <span class="text-yellow-500 shrink-0" title="Featured">★</span>
                        )}
                        <a
                          href={`/tool/${tool.slug}`}
                          class="font-semibold text-neutral-900 hover:text-green-600 transition-colors truncate"
                        >
                          {tool.name}
                        </a>
                        <span class="text-neutral-300 hidden sm:inline">—</span>
                        <a
                          href={tool.url}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="text-neutral-400 hover:text-neutral-600 text-sm shrink-0 transition-colors hidden sm:inline"
                        >
                          {hostname}
                        </a>
                      </div>
                      {tool.description && (
                        <span class="text-neutral-500 text-sm truncate">
                          <span class="text-neutral-300 hidden sm:inline">—</span>
                          {' '}{tool.description}
                        </span>
                      )}
                    </div>
                  </div>
                  {hl && (
                    <span class={`shrink-0 text-xs whitespace-nowrap ${hl.color}`}>
                      {hl.symbol} <span class="hidden sm:inline">{hl.text}</span>
                    </span>
                  )}
                </li>
              );
            })}
          </ul>
        </section>
      ))}
    </div>
  </div>

  <script is:inline>
    // Detect Mac for bookmark shortcut hint
    (function() {
      var isMac = /Mac|iPhone|iPad|iPod/.test(navigator.platform || '') || /Macintosh/.test(navigator.userAgent || '');
      if (isMac) {
        var keyEl = document.getElementById('bookmark-key');
        if (keyEl) keyEl.textContent = '⌘+D';
      }
    })();
  </script>
</Layout>
