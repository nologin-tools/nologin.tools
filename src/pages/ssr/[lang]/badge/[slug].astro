---
export const prerender = false;

import { getDb } from '../../../../db';
import { tools, tags, healthChecks } from '../../../../db/schema';
import { eq, desc } from 'drizzle-orm';
import BadgeDetailPage from '../../../../components/BadgeDetailPage.astro';
import type { Locale } from '../../../../i18n/config';

const { slug, lang } = Astro.params;
const locale = lang as Locale;
const siteUrl = Astro.locals.runtime.env.SITE_URL || 'https://nologin.tools';

let tool: any;
let toolTags: { tagKey: string; tagValue: string }[] = [];
let latestHealth: any;

try {
  const db = getDb(Astro.locals.runtime.env.DB);

  // Fetch tool
  const [result] = await db
    .select()
    .from(tools)
    .where(eq(tools.slug, slug!))
    .limit(1);

  tool = result;

  if (!tool || tool.status === 'rejected') {
    return new Response('<html><head><meta name="robots" content="noindex"><title>404 Not Found</title></head><body>Not Found</body></html>', {
      status: 404,
      headers: { 'Content-Type': 'text/html; charset=utf-8' },
    });
  }

  // Fetch tags
  toolTags = await db
    .select({ tagKey: tags.tagKey, tagValue: tags.tagValue })
    .from(tags)
    .where(eq(tags.toolId, tool.id));

  // Fetch latest health check
  const [health] = await db
    .select()
    .from(healthChecks)
    .where(eq(healthChecks.toolId, tool.id))
    .orderBy(desc(healthChecks.checkedAt))
    .limit(1);
  latestHealth = health;
} catch (err) {
  console.error('[ssr] badge page error:', err);
  return new Response('Internal Server Error', {
    status: 502,
    headers: { 'Content-Type': 'text/plain' },
  });
}
---

<BadgeDetailPage
  tool={tool}
  toolTags={toolTags}
  latestHealth={latestHealth ? { isOnline: latestHealth.isOnline, checkedAt: latestHealth.checkedAt } : null}
  slug={slug!}
  siteUrl={siteUrl}
  locale={locale}
/>
