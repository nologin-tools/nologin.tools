---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About" description="About nologin.tools — a curated directory of tools that work without login.">
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'NoLoginTools.org',
    url: 'https://nologintools.org',
    logo: 'https://nologin.tools/og-default.png',
    description: 'A curated directory of privacy-friendly tools that work without login.',
    sameAs: [
      'https://x.com/nologin_tools',
      'https://github.com/nologin-tools',
    ],
  })} />

  <div class="max-w-4xl mx-auto px-6 py-16 sm:py-24">
    <div class="mb-12">
      <h1 class="text-2xl font-bold tracking-tight text-neutral-900 mb-3">About nologin<span class="text-green-600">.</span>tools</h1>
      <p class="text-base text-neutral-500 max-w-2xl leading-relaxed">
        We believe the best tools are the ones that let you start working immediately, respecting both your time and your privacy.
      </p>
      <p class="text-sm text-neutral-400 mt-2">
        An open initiative by <a href="https://nologintools.org" target="_blank" rel="noopener noreferrer" class="text-green-600 hover:text-green-700 transition-colors font-semibold">NoLoginTools.org</a>
      </p>
    </div>

    <section class="border-b pb-8 mb-8">
      <h2 class="text-xl font-semibold text-neutral-900 mb-4">Our Mission</h2>
      <div class="text-base text-neutral-600 leading-relaxed space-y-3">
        <p>
          The internet has become increasingly fragmented by "walled gardens" and unnecessary friction.
          Simple tasks now often require a multi-step registration process, email verification, and the surrender of personal data.
        </p>
        <p class="font-semibold text-neutral-900">
          nologin.tools is a curated directory of high-quality software and services that let you get things done without creating an account.
        </p>
      </div>
    </section>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 border-b pb-8 mb-8">
      <section class="border rounded-lg p-6">
        <h2 class="text-lg font-semibold text-neutral-900 mb-4">Verification Process</h2>
        <ul class="space-y-3">
          {[
            "Reviewers manually verify every submission.",
            "We confirm core tasks work without login.",
            "Health checks monitor tool uptime daily.",
            "The community helps keep data accurate."
          ].map(item => (
            <li class="flex items-start gap-2 text-neutral-600 text-sm">
              <svg class="mt-0.5 shrink-0 text-green-500" width="16" height="16" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              {item}
            </li>
          ))}
        </ul>
      </section>

      <section class="border rounded-lg p-6">
        <h2 class="text-lg font-semibold text-neutral-900 mb-4">The Verified Badge</h2>
        <p class="text-sm text-neutral-600 leading-relaxed mb-4">
          Tool creators can display our badge to signal their commitment to a frictionless user experience.
        </p>
        <div class="flex items-center justify-center p-4 border rounded-lg mb-4">
           <img src="/badges/for-the-badge.svg" alt="NoLogin Verified" class="h-8" />
        </div>
        <a href="/badge" class="btn-minimal">Learn how to get yours &rarr;</a>
      </section>
    </div>

    <section class="pb-8">
      <p class="text-base text-neutral-600 leading-relaxed">
        nologin.tools is built on transparent principles by <a href="https://nologintools.org" target="_blank" rel="noopener noreferrer" class="text-green-600 hover:text-green-700 transition-colors font-semibold">NoLoginTools.org</a>. Our code is open source, and our database is exported regularly to help others build privacy-first applications.
        <a href="https://github.com/nologin-tools" target="_blank" rel="noopener noreferrer" class="btn-minimal">Explore on GitHub</a> · <a href="/submit" class="btn-minimal">Submit a Tool</a>
      </p>
    </section>
  </div>
</Layout>
