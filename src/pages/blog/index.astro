---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

function formatDate(date: Date): string {
  return date.toISOString().split('T')[0];
}

const blogLd = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: 'nologin.tools Blog',
  url: 'https://nologin.tools/blog',
  description: 'Articles about privacy-friendly tools, no-login workflows, and the open web.',
  blogPost: posts.map((post) => ({
    '@type': 'BlogPosting',
    headline: post.data.title,
    description: post.data.description,
    datePublished: formatDate(post.data.publishedAt),
    ...(post.data.updatedAt ? { dateModified: formatDate(post.data.updatedAt) } : {}),
    url: `https://nologin.tools/blog/${post.id}`,
    author: {
      '@type': 'Organization',
      name: post.data.author,
    },
  })),
};
---

<Layout
  title="Blog"
  description="Articles about privacy-friendly tools, no-login workflows, and the open web."
>
  <script type="application/ld+json" set:html={JSON.stringify(blogLd)} />

  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-12 sm:py-20">
    <header class="mb-12 border-b-4 border-neutral-900 pb-6">
      <h1 class="text-3xl sm:text-4xl font-black text-neutral-900 tracking-tight uppercase italic">
        Blog
      </h1>
      <p class="text-base text-neutral-600 mt-3">
        Articles about privacy-friendly tools and the open web.
      </p>
    </header>

    {posts.length === 0 ? (
      <p class="text-neutral-500">No posts yet. Check back soon.</p>
    ) : (
      <ul class="divide-y divide-neutral-200">
        {posts.map((post) => (
          <li class="py-6 first:pt-0">
            <a href={`/blog/${post.id}`} class="group block">
              <div class="flex flex-col sm:flex-row sm:items-baseline sm:gap-4">
                <time
                  datetime={formatDate(post.data.publishedAt)}
                  class="text-xs text-neutral-400 font-mono shrink-0"
                >
                  {formatDate(post.data.publishedAt)}
                </time>
                <h2 class="text-lg font-bold text-neutral-900 group-hover:underline decoration-2 underline-offset-4">
                  {post.data.title}
                </h2>
              </div>
              <p class="text-sm text-neutral-600 mt-2 sm:ml-[calc(10ch+1rem)]">
                {post.data.description}
              </p>
            </a>
          </li>
        ))}
      </ul>
    )}
  </div>
</Layout>
