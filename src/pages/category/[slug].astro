---
import CategoryPage from '../../components/CategoryPage.astro';
import { TAG_DEFINITIONS, categoryToSlug } from '../../lib/tags';

export function getStaticPaths() {
  const categoryDef = TAG_DEFINITIONS.find((d) => d.key === 'category');
  if (!categoryDef) return [];
  return categoryDef.values.map((cat) => ({
    params: { slug: categoryToSlug(cat) },
    props: { category: cat },
  }));
}

const { category } = Astro.props;
---

<CategoryPage locale="en" category={category} />
