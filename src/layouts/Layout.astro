---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { DEFAULT_LOCALE, LOCALES, LOCALE_OG_MAP, type Locale } from '../i18n/config';
import { t, loadTranslations, getLocalizedPath, getPathWithoutLocale } from '../i18n/utils';

interface Props {
  title: string;
  description?: string;
  ogType?: 'website' | 'article';
  ogImage?: string;
  ogImagePath?: string;
  bare?: boolean;
  hideHeader?: boolean;
  canonicalOverride?: string;
  publishedTime?: string;
  locale?: Locale;
}

const {
  title,
  description,
  ogType = 'website',
  ogImage = '/og-default.png',
  ogImagePath,
  bare = false,
  hideHeader = false,
  canonicalOverride,
  publishedTime,
  locale = DEFAULT_LOCALE,
} = Astro.props;

await loadTranslations(locale);

const defaultDescription = t(locale, 'layout.defaultDescription');
const desc = description || defaultDescription;

const fullTitle = `${title} | nologin.tools`;
const canonicalUrl = canonicalOverride
  ? new URL(canonicalOverride, 'https://nologin.tools').href
  : new URL(Astro.url.pathname, 'https://nologin.tools').href;
const siteUrl = Astro.site?.href || 'https://nologin.tools';
const ogImageUrl = ogImagePath
  ? new URL(ogImagePath, siteUrl).href
  : new URL(ogImage, siteUrl).href;
const ogImageWidth = ogImagePath ? 1200 : 1200;
const ogImageHeight = ogImagePath ? 630 : 630;

const ogLocale = LOCALE_OG_MAP[locale] || 'en_US';

// Generate hreflang links
const basePath = getPathWithoutLocale(canonicalOverride || Astro.url.pathname);
const hreflangLinks = LOCALES.map((l) => ({
  locale: l,
  href: new URL(getLocalizedPath(basePath, l), 'https://nologin.tools').href,
}));
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap.xml" />
    <link rel="preconnect" href="https://www.google.com" />
    <link rel="dns-prefetch" href="https://www.google.com" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#22c55e" />
    <title>{fullTitle}</title>
    <meta name="description" content={desc} />
    <link rel="canonical" href={canonicalUrl} />
    {hreflangLinks.map(({ locale: l, href }) => (
      <link rel="alternate" hreflang={l} href={href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={new URL(getLocalizedPath(basePath, DEFAULT_LOCALE), 'https://nologin.tools').href} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content={String(ogImageWidth)} />
    <meta property="og:image:height" content={String(ogImageHeight)} />
    <meta property="og:image:alt" content={fullTitle} />
    <meta property="og:site_name" content="nologin.tools" />
    <meta property="og:locale" content={ogLocale} />
    {ogType === 'article' && publishedTime && (
      <meta property="article:published_time" content={publishedTime} />
      <meta property="article:section" content="Tools" />
    )}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@nologin_tools" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={desc} />
    <meta name="twitter:image" content={ogImageUrl} />
  </head>
  <body>
    {!bare && !hideHeader && <Header locale={locale} />}
    <main>
      <slot />
    </main>
    {!bare && <Footer locale={locale} />}
  </body>
</html>
