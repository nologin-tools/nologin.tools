---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  ogType?: 'website' | 'article';
  ogImage?: string;
  bare?: boolean;
  canonicalOverride?: string;
  publishedTime?: string;
}

const {
  title,
  description = 'Discover tools that respect your privacy — no login required.',
  ogType = 'website',
  ogImage = '/og-default.png',
  bare = false,
  canonicalOverride,
  publishedTime,
} = Astro.props;

const fullTitle =
  title === 'Home' ? 'nologin.tools' : `${title} | nologin.tools`;
const canonicalUrl = canonicalOverride
  ? new URL(canonicalOverride, 'https://nologin.tools').href
  : Astro.url.href;
const siteUrl = Astro.site?.href || 'https://nologin.tools';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap.xml" />
    <meta name="theme-color" content="#22c55e" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={new URL(ogImage, siteUrl).href} />
    <meta property="og:site_name" content="nologin.tools" />
    <meta property="og:locale" content="en_US" />
    {ogType === 'article' && publishedTime && (
      <meta property="article:published_time" content={publishedTime} />
      <meta property="article:section" content="Tools" />
    )}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@nologin_tools" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
  </head>
  <body>
    {!bare && <Header />}
    <main>
      <slot />
    </main>
    {!bare && <Footer />}
  </body>
</html>
