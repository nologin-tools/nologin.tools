---
const year = new Date().getFullYear();
---

<footer class="border-t-2 border-neutral-900 mt-20 bg-neutral-50">
  <div
    class="max-w-3xl mx-auto px-6 py-12 flex flex-col sm:flex-row items-center justify-between gap-8 text-retro-mono"
  >
    <div class="flex flex-wrap items-center justify-center sm:justify-start gap-x-6 gap-y-2 text-xs font-bold uppercase tracking-wider">
      <a href="/about" class="text-neutral-500 hover:text-neutral-900 hover:underline decoration-2 underline-offset-4">About</a>
      <a
        href="https://github.com/nologin-tools"
        target="_blank"
        rel="noopener noreferrer"
        class="text-neutral-500 hover:text-neutral-900 hover:underline decoration-2 underline-offset-4">GitHub</a>
      <a
        href="https://x.com/nologin_tools"
        target="_blank"
        rel="noopener noreferrer"
        class="text-neutral-500 hover:text-neutral-900 hover:underline decoration-2 underline-offset-4">&#x1D54F;</a>
    </div>
    <div class="text-[10px] text-neutral-400 text-center sm:text-right font-bold uppercase tracking-tighter">
      <p>
        &copy; {year} NoLoginTools.org
      </p>
      <p class="mt-1">
        Flagship project: <a href="https://nologin.tools" class="text-neutral-500 hover:text-neutral-900">nologin.tools</a>
      </p>
    </div>
  </div>
</footer>
