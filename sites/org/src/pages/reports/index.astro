---
import Layout from '../../layouts/Layout.astro';
import ReportCard from '../../components/ReportCard.astro';
import { getCollection } from 'astro:content';

const reports = await getCollection('reports');
const sortedReports = reports.sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

const collectionLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Research Reports — NoLoginTools.org',
  url: 'https://nologintools.org/reports',
  description: 'Industry research and analysis on the No-Login Web ecosystem.',
  publisher: { '@id': 'https://nologintools.org/#organization' },
  mainEntity: {
    '@type': 'ItemList',
    itemListElement: sortedReports.map((report, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      item: {
        '@type': 'ScholarlyArticle',
        name: report.data.title,
        url: `https://nologintools.org/reports/${report.id}`,
      },
    })),
  },
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://nologintools.org' },
    { '@type': 'ListItem', position: 2, name: 'Reports' },
  ],
};
---

<Layout title="Reports" description="Industry research and analysis on the No-Login Web ecosystem by NoLoginTools.org.">
  <script type="application/ld+json" set:html={JSON.stringify([collectionLd, breadcrumbLd])} />

  <div class="max-w-3xl mx-auto px-6 py-12 sm:py-16">
    <!-- Breadcrumb -->
    <nav aria-label="Breadcrumb" class="mb-8">
      <ol class="flex items-center gap-2 text-sm font-bold text-neutral-400 text-retro-mono">
        <li><a href="/" class="hover:text-neutral-900 transition-colors">Home</a></li>
        <li aria-hidden="true" class="text-neutral-300">/</li>
        <li aria-current="page" class="text-neutral-900">Reports</li>
      </ol>
    </nav>

    <header class="mb-12">
      <h1 class="text-2xl sm:text-3xl font-black text-neutral-900 tracking-tight mb-3 text-retro-mono">
        Research Reports
      </h1>
      <p class="text-neutral-600">
        Industry research and analysis on the No-Login Web ecosystem, published by NoLoginTools.org.
      </p>
    </header>

    {sortedReports.length > 0 ? (
      <div class="space-y-6">
        {sortedReports.map((report) => (
          <ReportCard
            title={report.data.title}
            description={report.data.description}
            publishedAt={report.data.publishedAt}
            slug={report.id}
            tags={report.data.tags}
            version={report.data.version}
          />
        ))}
      </div>
    ) : (
      <p class="text-neutral-500 text-sm">No reports published yet. Check back soon.</p>
    )}
  </div>
</Layout>
